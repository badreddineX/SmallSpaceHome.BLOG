---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const pillars = [
  {
    title: 'Organization Tips.',
    sub: 'Practical systems that actually fit a rental.',
    desc: 'Practical systems for small apartments — drawers, closets, kitchens, and everything in between.',
  },
  {
    title: 'Budget Decor.',
    sub: 'Making a rental feel like home without the spend.',
    desc: 'Making a rental feel like home without spending a fortune or violating your lease.',
  },
  {
    title: 'Storage Solutions.',
    sub: 'Every hidden centimetre counts.',
    desc: 'I test real products from IKEA Canada, Amazon.ca, and beyond so you don\'t have to.',
  },
  {
    title: 'Renter Friendly.',
    sub: 'No drilling. No damage. No deposit lost.',
    desc: 'Everything on this site works within lease restrictions — Command strips, removable hooks, freestanding furniture.',
  },
  {
    title: 'Honest Reviews.',
    sub: 'I buy it, use it, then write about it.',
    desc: 'No sponsored fluff. If a product failed in my 510 sq ft Toronto apartment, I say so.',
  },
];
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="About — SmallSpace Home"
      description="The story behind SmallSpace Home — a Canadian apartment organization and decor blog for renters who want to love their space."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main class="about-page">

      <!-- ① HERO — full-bleed dark image with italic overlay -->
      <section class="about-hero">
        <img
          src="/images/about-hero-apartment.jpg"
          alt="Warm cozy apartment living room with natural light"
          class="about-hero-img"
          loading="eager"
          width="1800"
          height="900"
        />
        <div class="about-hero-overlay"></div>
        <div class="about-hero-content">
          <p class="hero-eyebrow">SmallSpace Home</p>
          <h1 class="hero-quote">
            It's not just a rental.<br />
            <em>It's our home.</em>
          </h1>
        </div>
      </section>

      <!-- ② OUR STORY — numbered + split -->
      <section class="about-intro">
        <div class="about-intro-img-wrap">
          <img src="/images/about-strip-shelf.jpg" alt="Organized small apartment shelf" class="about-intro-img" loading="lazy" width="900" height="1100" />
        </div>
        <div class="about-intro-body">
          <div class="section-num-header">
            <span class="section-num">01</span>
            <div class="section-num-line"></div>
          </div>
          <h2 class="about-intro-heading">Our Story</h2>
          <p>When I moved into my first Toronto apartment, I had a lot of stuff and almost no space. I spent months falling for Pinterest boards full of gorgeous minimalist homes that required either a renovation budget I didn't have or walls I wasn't allowed to touch.</p>
          <p>I started testing real solutions — things you can actually buy at IKEA Canada or Amazon.ca, things that mount with Command strips, things that fold and stack and do double-duty. Some of them worked brilliantly. A lot of them didn't. This blog is the honest record of both.</p>
          <p>If you're renting in Toronto, Vancouver, Montreal, or anywhere in Canada where apartments are expensive and small, this site is for you. No drilling required, no ridiculous budgets, no staged perfection.</p>
          <p class="intro-sig">— Badreddine Br, 510 sq ft · Toronto</p>
        </div>
      </section>

      <!-- ③ WHAT WE COVER — numbered category image grid -->
      <section class="categories-section">
        <div class="container">
          <div class="section-num-header">
            <span class="section-num">02</span>
            <div class="section-num-line"></div>
          </div>
          <h2 class="categories-heading">What We Cover</h2>
          <div class="categories-grid">
            <a href="/blog?category=Organization" class="cat-card">
              <div class="cat-card-img-wrap">
                <img src="/images/blog-03-img1.jpg" alt="Organization" loading="lazy" width="600" height="400" />
              </div>
              <span class="cat-card-label">Organization</span>
            </a>
            <a href="/blog?category=Decor" class="cat-card">
              <div class="cat-card-img-wrap">
                <img src="/images/blog-02-img1.jpg" alt="Decor" loading="lazy" width="600" height="400" />
              </div>
              <span class="cat-card-label">Decor</span>
            </a>
            <a href="/blog?category=Storage" class="cat-card">
              <div class="cat-card-img-wrap">
                <img src="/images/blog-04-img1.jpg" alt="Storage" loading="lazy" width="600" height="400" />
              </div>
              <span class="cat-card-label">Storage</span>
            </a>
            <a href="/blog?category=Budget+Tips" class="cat-card">
              <div class="cat-card-img-wrap">
                <img src="/images/blog-15-img1.jpg" alt="Budget Tips" loading="lazy" width="600" height="400" />
              </div>
              <span class="cat-card-label">Budget Tips</span>
            </a>
          </div>
        </div>
      </section>

      <!-- ④ ABOUT THE AUTHOR — horizontal card -->
      <section class="author-section">
        <div class="container">
          <div class="section-num-header">
            <span class="section-num">03</span>
            <div class="section-num-line"></div>
          </div>
          <div class="author-card">
            <div class="author-card-avatar">
              <div class="author-avatar-circle">
                <span class="author-initials">BB</span>
              </div>
            </div>
            <div class="author-card-body">
              <p class="author-card-eyebrow">About the Author</p>
              <h3 class="author-card-name">Hey, I'm Badreddine Br — Welcome to SmallSpace Home</h3>
              <p class="author-card-bio">A Canadian apartment renter obsessed with making small spaces work beautifully. I test real products, write honest guides, and share only what actually works in a real rental — no staged perfection, no sponsored fluff.</p>
              <a href="/blog" class="btn author-card-btn">Read the Blog →</a>
            </div>
          </div>
        </div>
      </section>

      <!-- ⑤ CONTACT -->
      <section class="contact-section" id="contact">
        <div class="contact-inner">

          <div class="contact-left">
            <span class="section-eyebrow">Get In Touch</span>
            <h2 class="contact-heading">Let's Connect</h2>
            <p class="contact-desc">
              Have a small space question, a product you want me to test, or just want to say hello? I read every message and reply within a few days.
            </p>
            <ol class="contact-steps">
              <li><span class="step-num">01</span><span>Fill in your name and email address</span></li>
              <li><span class="step-num">02</span><span>Tell me what's on your mind — questions, collabs, or just a hello</span></li>
              <li><span class="step-num">03</span><span>I'll get back to you within 2–3 business days</span></li>
            </ol>
          </div>

          <div class="contact-right">
            <form class="contact-form" method="POST" action="https://formsubmit.co/badreddinekx122@gmail.com">
              <input type="hidden" name="_subject" value="SmallSpaceHome — New Contact Message" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value="https://smallspacehome.vercel.app/thank-you" />
              <input type="text" name="_honey" style="display:none" />
              <div class="form-row">
                <div class="form-field">
                  <label for="cf-name">Full Name</label>
                  <input type="text" id="cf-name" name="name" placeholder="Your name" autocomplete="name" required />
                </div>
                <div class="form-field">
                  <label for="cf-email">Email Address</label>
                  <input type="email" id="cf-email" name="email" placeholder="your@email.com" autocomplete="email" required />
                </div>
              </div>
              <div class="form-field">
                <label for="cf-city">City / Province <span class="optional">(optional)</span></label>
                <input type="text" id="cf-city" name="city" placeholder="e.g. Toronto, ON" autocomplete="address-level2" />
              </div>
              <div class="form-field">
                <label for="cf-message">Message</label>
                <textarea id="cf-message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary form-submit">Send Message</button>
            </form>
          </div>

        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
.about-page { padding-bottom: 0; }

/* ── ① HERO ── */
.about-hero {
  position: relative;
  height: 92vh;
  min-height: 520px;
  max-height: 900px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.about-hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 35%;
  display: block;
}
.about-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10,10,10,0.20) 0%,
    rgba(10,10,10,0.50) 55%,
    rgba(10,10,10,0.82) 100%
  );
}
.about-hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 180px;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(255,255,255,0.50) 65%,
    rgba(255,255,255,1.00) 100%
  );
  z-index: 3;
  pointer-events: none;
}
.about-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 32px;
  max-width: 820px;
}
.hero-eyebrow {
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin: 0 0 28px;
}
.hero-quote {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 7vw, 5rem);
  font-weight: 400;
  line-height: 1.12;
  color: #fff;
  margin: 0;
  letter-spacing: -0.01em;
}
.hero-quote em {
  font-style: italic;
  color: var(--color-accent);
}

/* ── Numbered section header ── */
.section-num-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 16px;
}
.section-num {
  font-family: var(--font-display);
  font-size: 2.8rem;
  font-weight: 400;
  color: var(--color-accent-dark);
  line-height: 1;
  flex-shrink: 0;
}
.section-num-line {
  flex: 1;
  height: 1px;
  background: var(--color-accent);
}

/* ── ② OUR STORY ── */
.about-intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 600px;
  background: #fff;
  position: relative;
  margin-top: -2px;
  z-index: 2;
}
.about-intro::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 180px;
  background: linear-gradient(to bottom, transparent 0%, rgba(243,239,233,0.6) 60%, #F3EFE9 100%);
  z-index: 5;
  pointer-events: none;
}
.about-intro-img-wrap {
  overflow: hidden;
  position: relative;
}
.about-intro-img-wrap::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 180px;
  background: linear-gradient(to bottom, rgba(255,255,255,1.00) 0%, transparent 100%);
  z-index: 2;
  pointer-events: none;
}
.about-intro-img-wrap::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 180px;
  background: linear-gradient(to bottom, transparent 0%, rgba(243,239,233,0.92) 100%);
  z-index: 2;
  pointer-events: none;
}
.about-intro-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.about-intro-body {
  padding: 64px 56px;
  background: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.about-intro-heading {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  font-weight: 400;
  color: var(--color-ink);
  margin: 0 0 28px;
  line-height: 1.1;
}
.about-intro-body p {
  font-size: 0.95rem;
  line-height: 1.85;
  color: var(--color-text-muted);
  margin: 0 0 1.2rem;
}
.about-intro-body p:last-child { margin-bottom: 0; }
.intro-sig {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1rem !important;
  color: var(--color-accent-dark) !important;
  margin-top: 1.6rem !important;
}

/* ── ③ CATEGORIES GRID ── */
.categories-section {
  padding: 80px 24px;
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
}
.categories-heading {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  font-weight: 400;
  color: var(--color-ink);
  margin: 0 0 48px;
}
.categories-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
.cat-card {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.cat-card-img-wrap {
  overflow: hidden;
  border-radius: 4px;
  aspect-ratio: 3/4;
}
.cat-card-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.cat-card:hover .cat-card-img-wrap img { transform: scale(1.05); }
.cat-card-label {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-ink);
  transition: color 0.2s;
}
.cat-card:hover .cat-card-label { color: var(--color-accent-dark); }

/* ── ④ AUTHOR CARD ── */
.author-section {
  padding: 80px 24px;
  background: #fff;
  border-bottom: 1px solid var(--color-border);
}
.author-card {
  display: flex;
  align-items: center;
  gap: 40px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 48px 56px;
}
.author-avatar-circle {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--color-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.author-initials {
  font-family: var(--font-body);
  font-size: 1.1rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.05em;
}
.author-card-body { flex: 1; }
.author-card-eyebrow {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  margin: 0 0 8px;
}
.author-card-name {
  font-family: var(--font-display);
  font-size: clamp(1rem, 2vw, 1.4rem);
  font-weight: 400;
  color: var(--color-ink);
  margin: 0 0 14px;
  line-height: 1.3;
}
.author-card-bio {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.75;
  margin: 0 0 24px;
  max-width: 560px;
}
.author-card-btn {
  background: var(--color-accent-dark);
  color: #fff;
  border-color: var(--color-accent-dark);
  font-size: 0.78rem;
}
.author-card-btn:hover { background: #7a6040; border-color: #7a6040; }

.section-eyebrow {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  display: block;
  margin-bottom: 12px;
}

@media (max-width: 860px) {
  .about-intro { grid-template-columns: 1fr; }
  .about-intro-img-wrap { min-height: 320px; }
  .about-intro-body { padding: 48px 28px; }
  .categories-grid { grid-template-columns: repeat(2, 1fr); }
  .author-card { flex-direction: column; text-align: center; padding: 36px 28px; }
}
@media (max-width: 520px) {
  .categories-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
}

/* ── ⑤ CONTACT ── */
.contact-section {
  padding: 96px 24px 112px;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}
.contact-inner {
  max-width: 1040px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.contact-left { padding-top: 8px; }
.contact-heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 400;
  color: var(--color-heading);
  margin: 20px 0 20px;
  line-height: 1.1;
}
.contact-desc {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.8;
  margin-bottom: 36px;
  max-width: 380px;
}
.contact-steps {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.contact-steps li {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  font-size: 0.88rem;
  color: var(--color-text);
  line-height: 1.6;
  margin: 0;
}
.step-num {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--color-accent-dark);
  font-weight: 400;
  flex-shrink: 0;
  line-height: 1.4;
}
.contact-right {
  background: var(--color-white);
  padding: 48px 44px;
}
.contact-form { display: flex; flex-direction: column; gap: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.form-field { display: flex; flex-direction: column; gap: 8px; }
.form-field label {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-ink);
}
.optional {
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  font-weight: 400;
  text-transform: none;
}
.form-field input,
.form-field textarea {
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--color-border);
  border-radius: 0;
  padding: 10px 0;
  font-family: var(--font-body);
  font-size: 0.92rem;
  color: var(--color-ink);
  outline: none;
  transition: border-color var(--transition);
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
}
.form-field input::placeholder,
.form-field textarea::placeholder { color: var(--color-text-muted); font-size: 0.88rem; }
.form-field input:focus,
.form-field textarea:focus { border-bottom-color: var(--color-ink); }
.form-field textarea { resize: vertical; min-height: 120px; line-height: 1.7; }
.form-submit { align-self: flex-start; margin-top: 4px; padding-left: 36px; padding-right: 36px; }

/* ── Responsive ── */
@media (max-width: 860px) {
  .pillars-list, .pillars-header { padding: 0 24px; }
  .pillar-title { font-size: clamp(2rem, 8vw, 3.2rem); }
  .contact-inner { grid-template-columns: 1fr; gap: 48px; }
  .contact-desc { max-width: 100%; }
}
@media (max-width: 480px) {
  .about-hero { height: 80vh; }
  .pillars-section { padding: 64px 0 56px; }
  .pillar-content { padding: 36px 0 32px; gap: 10px; }
  .contact-right { padding: 32px 20px; }
  .form-row { grid-template-columns: 1fr; }
  .form-submit { align-self: stretch; }
}
</style>
