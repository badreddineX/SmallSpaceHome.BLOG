---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const pillars = [
  {
    title: 'Organization Tips.',
    sub: 'Practical systems that actually fit a rental.',
    desc: 'Practical systems for small apartments — drawers, closets, kitchens, and everything in between.',
  },
  {
    title: 'Budget Decor.',
    sub: 'Making a rental feel like home without the spend.',
    desc: 'Making a rental feel like home without spending a fortune or violating your lease.',
  },
  {
    title: 'Storage Solutions.',
    sub: 'Every hidden centimetre counts.',
    desc: 'I test real products from IKEA Canada, Amazon.ca, and beyond so you don\'t have to.',
  },
  {
    title: 'Renter Friendly.',
    sub: 'No drilling. No damage. No deposit lost.',
    desc: 'Everything on this site works within lease restrictions — Command strips, removable hooks, freestanding furniture.',
  },
  {
    title: 'Honest Reviews.',
    sub: 'I buy it, use it, then write about it.',
    desc: 'No sponsored fluff. If a product failed in my 510 sq ft Toronto apartment, I say so.',
  },
];
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="About — SmallSpace Home"
      description="The story behind SmallSpace Home — a Canadian apartment organization and decor blog for renters who want to love their space."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main class="about-page">

      <!-- ① HERO — full-bleed dark image with italic overlay -->
      <section class="about-hero">
        <img
          src="/images/about-hero-apartment.jpg"
          alt="Warm cozy apartment living room with natural light"
          class="about-hero-img"
          loading="eager"
          width="1800"
          height="900"
        />
        <div class="about-hero-overlay"></div>
        <div class="about-hero-content">
          <p class="hero-eyebrow">SmallSpace Home</p>
          <h1 class="hero-quote">
            It's not just a rental.<br />
            <em>It's our home.</em>
          </h1>
        </div>
      </section>

      <!-- ② WHO WE ARE -->
      <section class="about-intro">
        <div class="about-intro-inner">
          <div class="about-intro-label">
            <span class="section-eyebrow">Our Story</span>
          </div>
          <div class="about-intro-body">
            <p>
              When I moved into my first Toronto apartment, I had a lot of stuff and almost no space. I spent months falling for Pinterest boards full of gorgeous minimalist homes that required either a renovation budget I didn't have or walls I wasn't allowed to touch.
            </p>
            <p>
              I started testing real solutions — things you can actually buy at IKEA Canada or Amazon.ca, things that mount with Command strips, things that fold and stack and do double-duty. Some of them worked brilliantly. A lot of them didn't. This blog is the honest record of both.
            </p>
            <p>
              If you're renting in Toronto, Vancouver, Montreal, or anywhere in Canada where apartments are expensive and small, this site is for you. No drilling required, no ridiculous budgets, no staged perfection.
            </p>
            <p class="intro-sig">— Sarah Mitchell, 510 sq ft · Toronto</p>
          </div>
        </div>
      </section>

      <!-- ③ DIVIDER IMAGE -->
      <div class="mid-image-wrap">
        <img
          src="/images/blog-01-img1.jpg"
          alt="Organized small apartment interior"
          class="mid-image"
          loading="lazy"
          width="1800"
          height="700"
        />
        <div class="mid-image-overlay"></div>
      </div>

      <!-- ④ WHAT YOU'LL FIND — editorial big-type list -->
      <section class="pillars-section">
        <div class="pillars-header">
          <span class="section-eyebrow">What You'll Find Here</span>
        </div>

        <div class="pillars-list">
          {pillars.map(p => (
            <div class="pillar-item">
              <div class="pillar-accent-line"></div>
              <div class="pillar-content">
                <h2 class="pillar-title">{p.title}</h2>
                <p class="pillar-sub">{p.sub}</p>
              </div>
            </div>
          ))}
          <div class="pillar-accent-line"></div>
        </div>
      </section>

      <!-- ⑤ CONTACT -->
      <section class="contact-section" id="contact">
        <div class="contact-inner">

          <div class="contact-left">
            <span class="section-eyebrow">Get In Touch</span>
            <h2 class="contact-heading">Let's Connect</h2>
            <p class="contact-desc">
              Have a small space question, a product you want me to test, or just want to say hello? I read every message and reply within a few days.
            </p>
            <ol class="contact-steps">
              <li><span class="step-num">01</span><span>Fill in your name and email address</span></li>
              <li><span class="step-num">02</span><span>Tell me what's on your mind — questions, collabs, or just a hello</span></li>
              <li><span class="step-num">03</span><span>I'll get back to you within 2–3 business days</span></li>
            </ol>
          </div>

          <div class="contact-right">
            <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you">
              <input type="hidden" name="form-name" value="contact" />
              <p style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>
              <div class="form-row">
                <div class="form-field">
                  <label for="cf-name">Full Name</label>
                  <input type="text" id="cf-name" name="name" placeholder="Your name" autocomplete="name" required />
                </div>
                <div class="form-field">
                  <label for="cf-email">Email Address</label>
                  <input type="email" id="cf-email" name="email" placeholder="your@email.com" autocomplete="email" required />
                </div>
              </div>
              <div class="form-field">
                <label for="cf-city">City / Province <span class="optional">(optional)</span></label>
                <input type="text" id="cf-city" name="city" placeholder="e.g. Toronto, ON" autocomplete="address-level2" />
              </div>
              <div class="form-field">
                <label for="cf-message">Message</label>
                <textarea id="cf-message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary form-submit">Send Message</button>
            </form>
          </div>

        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
.about-page { padding-bottom: 0; }

/* ── ① HERO ── */
.about-hero {
  position: relative;
  height: 92vh;
  min-height: 520px;
  max-height: 900px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.about-hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 35%;
  display: block;
}
.about-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10,10,10,0.25) 0%,
    rgba(10,10,10,0.55) 60%,
    rgba(10,10,10,0.70) 100%
  );
}
.about-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 32px;
  max-width: 820px;
}
.hero-eyebrow {
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin: 0 0 28px;
}
.hero-quote {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 7vw, 5rem);
  font-weight: 400;
  line-height: 1.12;
  color: #fff;
  margin: 0;
  letter-spacing: -0.01em;
}
.hero-quote em {
  font-style: italic;
  color: var(--color-accent);
}

/* ── ② INTRO ── */
.about-intro {
  padding: 96px 24px;
  border-bottom: 1px solid var(--color-border);
}
.about-intro-inner {
  max-width: 1040px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 80px;
  align-items: start;
}
.about-intro-label { padding-top: 6px; }
.section-eyebrow {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  display: block;
}
.about-intro-body p {
  font-size: 1.05rem;
  line-height: 1.9;
  color: var(--color-text);
  margin: 0 0 1.4rem;
  max-width: 600px;
}
.about-intro-body p:last-child { margin-bottom: 0; }
.intro-sig {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1rem !important;
  color: var(--color-text-muted) !important;
  margin-top: 2.4rem !important;
}

/* ── ③ MID IMAGE ── */
.mid-image-wrap {
  position: relative;
  height: 52vh;
  min-height: 280px;
  max-height: 560px;
  overflow: hidden;
}
.mid-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 40%;
  display: block;
}
.mid-image-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10,10,10,0.32);
}

/* ── ④ PILLARS — editorial big-type ── */
.pillars-section {
  padding: 96px 0 80px;
  background: var(--color-white);
}
.pillars-header {
  max-width: 1040px;
  margin: 0 auto 56px;
  padding: 0 48px;
}
.pillars-list {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 48px;
}
.pillar-item {
  position: relative;
}
.pillar-accent-line {
  height: 1px;
  background: var(--color-border);
  margin: 0;
}
.pillar-content {
  padding: 48px 0 44px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
}
.pillar-title {
  font-family: var(--font-display);
  font-size: clamp(2.6rem, 6.5vw, 5rem);
  font-weight: 400;
  color: var(--color-heading);
  margin: 0;
  line-height: 1.05;
  letter-spacing: -0.02em;
}
.pillar-sub {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(0.85rem, 1.4vw, 1rem);
  color: var(--color-text-faint);
  margin: 0;
  letter-spacing: 0.01em;
}

/* ── ⑤ CONTACT ── */
.contact-section {
  padding: 96px 24px 112px;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}
.contact-inner {
  max-width: 1040px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.contact-left { padding-top: 8px; }
.contact-heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 400;
  color: var(--color-heading);
  margin: 20px 0 20px;
  line-height: 1.1;
}
.contact-desc {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.8;
  margin-bottom: 36px;
  max-width: 380px;
}
.contact-steps {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.contact-steps li {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  font-size: 0.88rem;
  color: var(--color-text);
  line-height: 1.6;
  margin: 0;
}
.step-num {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--color-accent-dark);
  font-weight: 400;
  flex-shrink: 0;
  line-height: 1.4;
}
.contact-right {
  background: var(--color-white);
  padding: 48px 44px;
}
.contact-form { display: flex; flex-direction: column; gap: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.form-field { display: flex; flex-direction: column; gap: 8px; }
.form-field label {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-ink);
}
.optional {
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  font-weight: 400;
  text-transform: none;
}
.form-field input,
.form-field textarea {
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--color-border);
  border-radius: 0;
  padding: 10px 0;
  font-family: var(--font-body);
  font-size: 0.92rem;
  color: var(--color-ink);
  outline: none;
  transition: border-color var(--transition);
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
}
.form-field input::placeholder,
.form-field textarea::placeholder { color: var(--color-text-muted); font-size: 0.88rem; }
.form-field input:focus,
.form-field textarea:focus { border-bottom-color: var(--color-ink); }
.form-field textarea { resize: vertical; min-height: 120px; line-height: 1.7; }
.form-submit { align-self: flex-start; margin-top: 4px; padding-left: 36px; padding-right: 36px; }

/* ── Responsive ── */
@media (max-width: 860px) {
  .about-intro-inner { grid-template-columns: 1fr; gap: 32px; }
  .about-intro-label { padding-top: 0; }
  .pillars-list, .pillars-header { padding: 0 24px; }
  .pillar-title { font-size: clamp(2rem, 8vw, 3.2rem); }
  .contact-inner { grid-template-columns: 1fr; gap: 48px; }
  .contact-desc { max-width: 100%; }
}
@media (max-width: 480px) {
  .about-hero { height: 80vh; }
  .pillars-section { padding: 64px 0 56px; }
  .pillar-content { padding: 36px 0 32px; gap: 10px; }
  .contact-right { padding: 32px 20px; }
  .form-row { grid-template-columns: 1fr; }
  .form-submit { align-self: stretch; }
}
</style>
