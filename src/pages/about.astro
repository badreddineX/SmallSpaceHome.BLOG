---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const pillars = [
  {
    title: 'Organization Tips.',
    sub: 'Practical systems that actually fit a rental.',
    desc: 'Practical systems for small apartments — drawers, closets, kitchens, and everything in between.',
  },
  {
    title: 'Budget Decor.',
    sub: 'Making a rental feel like home without the spend.',
    desc: 'Making a rental feel like home without spending a fortune or violating your lease.',
  },
  {
    title: 'Storage Solutions.',
    sub: 'Every hidden centimetre counts.',
    desc: 'I test real products from IKEA Canada, Amazon.ca, and beyond so you don\'t have to.',
  },
  {
    title: 'Renter Friendly.',
    sub: 'No drilling. No damage. No deposit lost.',
    desc: 'Everything on this site works within lease restrictions — Command strips, removable hooks, freestanding furniture.',
  },
  {
    title: 'Honest Reviews.',
    sub: 'I buy it, use it, then write about it.',
    desc: 'No sponsored fluff. If a product failed in my 510 sq ft Toronto apartment, I say so.',
  },
];
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="About — SmallSpace Home"
      description="The story behind SmallSpace Home — a Canadian apartment organization and decor blog for renters who want to love their space."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main class="about-page">

      <!-- ① HERO — full-bleed dark image with italic overlay -->
      <section class="about-hero">
        <img
          src="/images/about-hero-apartment.jpg"
          alt="Warm cozy apartment living room with natural light"
          class="about-hero-img"
          loading="eager"
          width="1800"
          height="900"
        />
        <div class="about-hero-overlay"></div>
        <div class="about-hero-content">
          <p class="hero-eyebrow">SmallSpace Home</p>
          <h1 class="hero-quote">
            It's not just a rental.<br />
            <em>It's our home.</em>
          </h1>
        </div>
      </section>

      <!-- ② WHO WE ARE -->
      <section class="about-intro">

        <!-- Left: image -->
        <div class="about-intro-img-wrap">
          <img
            src="/images/about-strip-shelf.jpg"
            alt="Organized small apartment shelf"
            class="about-intro-img"
            loading="lazy"
            width="900"
            height="1100"
          />
        </div>

        <!-- Right: content -->
        <div class="about-intro-body">
          <div class="author-photo-wrap">
            <div class="author-avatar-circle">
              <span class="author-initials">BB</span>
            </div>
            <span class="author-photo-name">Badreddine Br</span>
          </div>
          <span class="section-eyebrow">Our Story</span>
          <h2 class="about-intro-heading">About SmallSpace Home</h2>
          <p>
            When I moved into my first Toronto apartment, I had a lot of stuff and almost no space. I spent months falling for Pinterest boards full of gorgeous minimalist homes that required either a renovation budget I didn't have or walls I wasn't allowed to touch.
          </p>
          <p>
            I started testing real solutions — things you can actually buy at IKEA Canada or Amazon.ca, things that mount with Command strips, things that fold and stack and do double-duty. Some of them worked brilliantly. A lot of them didn't. This blog is the honest record of both.
          </p>
          <p>
            If you're renting in Toronto, Vancouver, Montreal, or anywhere in Canada where apartments are expensive and small, this site is for you. No drilling required, no ridiculous budgets, no staged perfection.
          </p>
          <p class="intro-sig">— Badreddine Br, 510 sq ft · Toronto</p>
        </div>

      </section>

      <!-- ④ WHAT YOU'LL FIND — numbered editorial grid -->
      <section class="pillars-section">
        <div class="container">
          <div class="pillars-header">
            <span class="section-eyebrow">What You'll Find Here</span>
            <h2 class="pillars-title">Everything a Canadian renter needs</h2>
          </div>
          <div class="pillars-grid">
            {pillars.map((p, i) => (
              <div class="pillar-card">
                <div class="pillar-number-row">
                  <span class="pillar-number">0{i + 1}</span>
                  <div class="pillar-number-line"></div>
                </div>
                <h3 class="pillar-card-title">{p.title}</h3>
                <p class="pillar-card-desc">{p.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ⑤ CONTACT -->
      <section class="contact-section" id="contact">
        <div class="contact-inner">

          <div class="contact-left">
            <span class="section-eyebrow">Get In Touch</span>
            <h2 class="contact-heading">Let's Connect</h2>
            <p class="contact-desc">
              Have a small space question, a product you want me to test, or just want to say hello? I read every message and reply within a few days.
            </p>
            <ol class="contact-steps">
              <li><span class="step-num">01</span><span>Fill in your name and email address</span></li>
              <li><span class="step-num">02</span><span>Tell me what's on your mind — questions, collabs, or just a hello</span></li>
              <li><span class="step-num">03</span><span>I'll get back to you within 2–3 business days</span></li>
            </ol>
          </div>

          <div class="contact-right">
            <form class="contact-form" method="POST" action="https://formsubmit.co/badreddinekx122@gmail.com">
              <input type="hidden" name="_subject" value="SmallSpaceHome — New Contact Message" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value="https://smallspacehome.vercel.app/thank-you" />
              <input type="text" name="_honey" style="display:none" />
              <div class="form-row">
                <div class="form-field">
                  <label for="cf-name">Full Name</label>
                  <input type="text" id="cf-name" name="name" placeholder="Your name" autocomplete="name" required />
                </div>
                <div class="form-field">
                  <label for="cf-email">Email Address</label>
                  <input type="email" id="cf-email" name="email" placeholder="your@email.com" autocomplete="email" required />
                </div>
              </div>
              <div class="form-field">
                <label for="cf-city">City / Province <span class="optional">(optional)</span></label>
                <input type="text" id="cf-city" name="city" placeholder="e.g. Toronto, ON" autocomplete="address-level2" />
              </div>
              <div class="form-field">
                <label for="cf-message">Message</label>
                <textarea id="cf-message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
              </div>
              <button type="submit" class="btn btn-primary form-submit">Send Message</button>
            </form>
          </div>

        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
.about-page { padding-bottom: 0; }

/* ── ① HERO ── */
.about-hero {
  position: relative;
  height: 92vh;
  min-height: 520px;
  max-height: 900px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.about-hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 35%;
  display: block;
}
.about-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(10,10,10,0.25) 0%,
    rgba(10,10,10,0.55) 60%,
    rgba(10,10,10,0.70) 100%
  );
}
.about-hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 0 32px;
  max-width: 820px;
}
.hero-eyebrow {
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin: 0 0 28px;
}
.hero-quote {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 7vw, 5rem);
  font-weight: 400;
  line-height: 1.12;
  color: #fff;
  margin: 0;
  letter-spacing: -0.01em;
}
.hero-quote em {
  font-style: italic;
  color: var(--color-accent);
}

/* ── ② INTRO ── */
.about-intro {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 600px;
  border-bottom: 1px solid var(--color-border);
}

.about-intro-img-wrap {
  overflow: hidden;
  position: relative;
}
.about-intro-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.about-intro-body {
  padding: 72px 64px;
  background: #fff;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.section-eyebrow {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  display: block;
  margin-bottom: 12px;
}

.about-intro-heading {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 400;
  color: var(--color-ink);
  margin: 0 0 28px;
  line-height: 1.2;
}

.about-intro-body p {
  font-size: 0.95rem;
  line-height: 1.85;
  color: var(--color-text-muted);
  margin: 0 0 1.2rem;
}
.about-intro-body p:last-child { margin-bottom: 0; }

.intro-sig {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1rem !important;
  color: var(--color-accent-dark) !important;
  margin-top: 1.6rem !important;
}

.author-photo-wrap {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 24px;
}
.author-avatar-circle {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--color-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.author-initials {
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.05em;
}
.author-photo-name {
  font-family: var(--font-display);
  font-size: 1rem;
  font-style: italic;
  color: var(--color-accent-dark);
}

@media (max-width: 860px) {
  .about-intro { grid-template-columns: 1fr; }
  .about-intro-img-wrap { min-height: 320px; }
  .about-intro-body { padding: 48px 28px; }
}

/* ── ④ PILLARS — numbered editorial grid ── */
.pillars-section {
  padding: 96px 24px 96px;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}
.pillars-header {
  margin-bottom: 56px;
}
.pillars-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 400;
  color: var(--color-ink);
  margin: 12px 0 0;
  line-height: 1.2;
}
.pillars-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px 48px;
}
.pillar-card {
  background: #fff;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  padding: 36px 32px;
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.pillar-card:hover {
  box-shadow: 0 8px 24px rgba(139,111,71,0.10);
  transform: translateY(-3px);
}
.pillar-number-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}
.pillar-number {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 400;
  color: var(--color-accent-dark);
  line-height: 1;
  flex-shrink: 0;
}
.pillar-number-line {
  flex: 1;
  height: 1px;
  background: var(--color-accent);
}
.pillar-card-title {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--color-ink);
  margin: 0 0 12px;
  line-height: 1.3;
}
.pillar-card-desc {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  line-height: 1.75;
  margin: 0;
}

@media (max-width: 860px) {
  .pillars-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}
@media (max-width: 520px) {
  .pillars-grid { grid-template-columns: 1fr; }
}

/* ── ⑤ CONTACT ── */
.contact-section {
  padding: 96px 24px 112px;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}
.contact-inner {
  max-width: 1040px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.contact-left { padding-top: 8px; }
.contact-heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 400;
  color: var(--color-heading);
  margin: 20px 0 20px;
  line-height: 1.1;
}
.contact-desc {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.8;
  margin-bottom: 36px;
  max-width: 380px;
}
.contact-steps {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.contact-steps li {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  font-size: 0.88rem;
  color: var(--color-text);
  line-height: 1.6;
  margin: 0;
}
.step-num {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--color-accent-dark);
  font-weight: 400;
  flex-shrink: 0;
  line-height: 1.4;
}
.contact-right {
  background: var(--color-white);
  padding: 48px 44px;
}
.contact-form { display: flex; flex-direction: column; gap: 28px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
.form-field { display: flex; flex-direction: column; gap: 8px; }
.form-field label {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-ink);
}
.optional {
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  font-weight: 400;
  text-transform: none;
}
.form-field input,
.form-field textarea {
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--color-border);
  border-radius: 0;
  padding: 10px 0;
  font-family: var(--font-body);
  font-size: 0.92rem;
  color: var(--color-ink);
  outline: none;
  transition: border-color var(--transition);
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
}
.form-field input::placeholder,
.form-field textarea::placeholder { color: var(--color-text-muted); font-size: 0.88rem; }
.form-field input:focus,
.form-field textarea:focus { border-bottom-color: var(--color-ink); }
.form-field textarea { resize: vertical; min-height: 120px; line-height: 1.7; }
.form-submit { align-self: flex-start; margin-top: 4px; padding-left: 36px; padding-right: 36px; }

/* ── Responsive ── */
@media (max-width: 860px) {
  .pillars-list, .pillars-header { padding: 0 24px; }
  .pillar-title { font-size: clamp(2rem, 8vw, 3.2rem); }
  .contact-inner { grid-template-columns: 1fr; gap: 48px; }
  .contact-desc { max-width: 100%; }
}
@media (max-width: 480px) {
  .about-hero { height: 80vh; }
  .pillars-section { padding: 64px 0 56px; }
  .pillar-content { padding: 36px 0 32px; gap: 10px; }
  .contact-right { padding: 32px 20px; }
  .form-row { grid-template-columns: 1fr; }
  .form-submit { align-self: stretch; }
}
</style>
