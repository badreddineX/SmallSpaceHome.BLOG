---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Page Not Found"
      description="The page you're looking for doesn't exist. Browse our organization and decor ideas for Canadian apartments."
    />
  </head>
  <body>
    <Header />

    <main class="error-main">
      <div class="error-inner">
        <span class="error-code">404</span>
        <h1 class="error-heading">Page not found</h1>
        <p class="error-body">
          This page doesn't exist or may have moved. Try browsing our posts below, or head back home.
        </p>
        <div class="error-actions">
          <a href="/" class="err-btn err-btn-primary">Back to Home</a>
          <a href="/blog" class="err-btn err-btn-secondary">Browse All Posts</a>
        </div>

        <div class="error-links">
          <p class="error-links-label">Popular reads</p>
          <ul>
            <li><a href="/blog/apartment-decor-ideas/">Apartment Decor Ideas for Canadian Renters</a></li>
            <li><a href="/blog/small-apartment-organization/">Complete Small Apartment Organization Guide</a></li>
            <li><a href="/blog/storage-ideas-for-small-places/">23 Storage Ideas for Small Apartments</a></li>
            <li><a href="/blog/ikea-small-space-hacks/">IKEA Small Space Hacks</a></li>
            <li><a href="/blog/studio-apartment-ideas/">Studio Apartment Ideas That Actually Work</a></li>
          </ul>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
.error-main {
  min-height: calc(100vh - var(--header-height) - 320px);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 24px;
}
.error-inner {
  max-width: 560px;
  width: 100%;
  text-align: center;
}
.error-code {
  display: block;
  font-family: var(--font-display);
  font-size: clamp(5rem, 20vw, 9rem);
  font-weight: 400;
  color: var(--color-border);
  line-height: 1;
  margin-bottom: 8px;
  letter-spacing: -0.04em;
}
.error-heading {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 400;
  color: var(--color-heading);
  margin: 0 0 16px;
  line-height: 1.2;
}
.error-body {
  font-size: 1rem;
  color: var(--color-text-muted);
  line-height: 1.75;
  margin: 0 0 36px;
}
.error-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: center;
  margin-bottom: 56px;
}
.error-links {
  border-top: 1px solid var(--color-border);
  padding-top: 36px;
  text-align: left;
}
.error-links-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin: 0 0 16px;
}
.error-links ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.error-links li a {
  font-size: 0.9rem;
  color: var(--color-accent-dark);
  text-decoration: none;
  display: block;
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border);
  transition: color var(--transition);
}
.error-links li:last-child a { border-bottom: none; }
.error-links li a:hover { color: var(--color-ink); }

.err-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 13px 28px;
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: background var(--transition), color var(--transition), border-color var(--transition);
  min-height: 48px;
}
.err-btn-primary {
  background: var(--color-ink);
  color: #fff;
  border: 1px solid var(--color-ink);
}
.err-btn-primary:hover { background: #333; border-color: #333; }
.err-btn-secondary {
  background: transparent;
  color: var(--color-ink);
  border: 1px solid var(--color-border);
}
.err-btn-secondary:hover { border-color: var(--color-ink); }

@media (max-width: 480px) {
  .error-actions { flex-direction: column; align-items: center; }
  .err-btn { width: 100%; max-width: 280px; }
}
</style>
