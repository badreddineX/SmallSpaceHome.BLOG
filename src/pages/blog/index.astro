---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';

const allPosts = await getCollection('blog');
const sorted   = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const categories = ['All', 'Organization', 'Decor', 'Storage', 'Budget Tips'];

const catClass: Record<string, string> = {
  'Organization': 'cat-organization',
  'Decor':        'cat-decor',
  'Storage':      'cat-storage',
  'Budget Tips':  'cat-budget-tips',
};

const POSTS_PER_PAGE = 6;
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {sorted[0] && <link rel="preload" as="image" href={sorted[0].data.image} />}
    {sorted[1] && <link rel="preload" as="image" href={sorted[1].data.image} />}
    {sorted[2] && <link rel="preload" as="image" href={sorted[2].data.image} />}
    <SEO
      title="Blog — SmallSpace Home"
      description="All posts on organization, decor, storage, and budget tips for Canadian apartment renters. Browse by category or start from the top."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main>
      <!-- Editorial hero -->
      <section class="read-hero">
        <div class="read-hero-bg" aria-hidden="true"></div>
        <div class="read-hero-content">
          <h1 class="read-hero-title">
            Read All<br />
            <em>Organization &amp; Decor</em>
          </h1>
        </div>
      </section>

      <!-- Keyword search bar -->
      <div class="search-bar-wrap">
        <div class="search-bar-inner">
          <label for="post-search" class="sr-only">Search posts</label>
          <div class="search-field">
            <svg class="search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              type="search"
              id="post-search"
              class="search-input"
              placeholder="Search by keyword — organization, IKEA, budget…"
              autocomplete="off"
              spellcheck="false"
            />
            <button class="search-clear" id="search-clear" aria-label="Clear search" hidden>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
          <ul class="search-suggestions" id="search-suggestions" role="listbox" aria-label="Search suggestions" hidden></ul>
        </div>
      </div>

      <!-- Category filter -->
      <div class="filter-bar" id="filter-bar">
        <nav class="filter-tabs" role="tablist" aria-label="Filter by category">
          {categories.map(cat => (
            <button
              class={`filter-tab${cat === 'All' ? ' active' : ''}`}
              data-category={cat}
              role="tab"
              aria-selected={cat === 'All' ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </nav>
      </div>

      <!-- Posts grid -->
      <section class="posts-section">
        <div class="posts-grid" id="posts-grid">
          {sorted.map((post, i) => {
            const date = new Date(post.data.datePublished).toLocaleDateString('en-CA', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <article
                class="post-item"
                data-category={post.data.category}
                data-title={post.data.title.toLowerCase()}
                data-desc={post.data.description.toLowerCase()}
                data-slug={post.slug}
                data-tags={(post.data.tags ?? []).join(' ').toLowerCase()}
              >
                <a href={`/blog/${post.slug}`} class="post-img-link">
                  <div class="post-img-wrap img-placeholder">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      loading={i < 6 ? 'eager' : 'lazy'}
                      decoding={i < 6 ? 'sync' : 'async'}
                      width="800"
                      height="1066"
                      onerror="this.parentElement.classList.add('img-error')"
                    />
                  </div>
                </a>
                <div class="post-info">
                  <span class={`post-cat ${catClass[post.data.category] ?? 'cat-organization'}`}>
                    {post.data.category}
                  </span>
                  <h2 class="post-title">
                    <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                  </h2>
                  <p class="post-meta">
                    <time datetime={post.data.datePublished}>{date}</time>
                    <span aria-hidden="true">·</span>
                    <span>{post.data.readTime} min read</span>
                  </p>
                </div>
              </article>
            );
          })}
        </div>

        <p class="no-results" id="no-results" hidden>
          No posts in this category yet — check back soon!
        </p>

        <!-- Pagination controls -->
        <div class="pagination" id="pagination" aria-label="Pagination">
          <button class="page-arrow" id="prev-btn" aria-label="Previous page" disabled>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>

          <div class="page-numbers" id="page-numbers"></div>

          <button class="page-arrow" id="next-btn" aria-label="Next page">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>

      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
/* ── Hero ── */
.read-hero {
  position: relative;
  text-align: center;
  padding: 0;
  overflow: hidden;
  border-bottom: 1px solid var(--color-border);
}

.read-hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('/images/about-hero-apartment.jpg');
  background-size: cover;
  background-position: center 40%;
  filter: blur(2px) brightness(0.55);
  transform: scale(1.05);
}

.read-hero-content {
  position: relative;
  z-index: 1;
  padding: 90px 24px 70px;
}

.read-hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 6vw, 4.2rem);
  font-weight: 400;
  line-height: 1.12;
  color: #fff;
  margin: 0;
}

.read-hero-title em {
  font-style: italic;
  font-weight: 400;
  color: var(--color-accent);
}

/* ── Search bar ── */
.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

.search-bar-wrap {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  padding: 10px 24px;
}

.search-bar-inner {
  max-width: 560px;
  margin: 0;
}

.search-field {
  display: flex;
  align-items: center;
  gap: 7px;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  padding: 7px 12px;
  transition: border-color var(--transition);
}
.search-field:focus-within { border-color: var(--color-ink); }

.search-icon {
  color: var(--color-text-faint);
  flex-shrink: 0;
  width: 13px;
  height: 13px;
  transition: color var(--transition);
}
.search-field:focus-within .search-icon { color: var(--color-text-muted); }

.search-input {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  font-family: var(--font-body);
  font-size: 16px;
  color: var(--color-ink);
  min-height: 28px;
  -webkit-appearance: none;
  letter-spacing: 0.02em;
}
.search-input::placeholder { color: var(--color-text-faint); font-size: 16px; }
.search-input::-webkit-search-cancel-button { display: none; }

.search-clear {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-faint);
  padding: 2px;
  display: flex;
  align-items: center;
  transition: color var(--transition);
  -webkit-tap-highlight-color: transparent;
}
.search-clear:hover { color: var(--color-ink); }

/* ── Search suggestions ── */
.search-bar-inner { position: relative; }

:global(.search-suggestions) {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  right: 0;
  background: #FAFAF7;
  border: 1px solid #E5DDD3;
  border-radius: 6px;
  box-shadow: 0 12px 32px rgba(28,25,23,0.10);
  list-style: none;
  margin: 0;
  padding: 6px 0;
  z-index: 200;
  max-height: 300px;
  overflow-y: auto;
}
:global(.search-suggestions li) {
  border-bottom: 1px solid rgba(229,221,211,0.5);
}
:global(.search-suggestions li:last-child) {
  border-bottom: none;
}
:global(.search-suggestions li a) {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 11px 16px;
  text-decoration: none;
  color: #1C1917;
  font-family: 'Inter', sans-serif;
  font-size: 0.84rem;
  line-height: 1.3;
  transition: background 0.15s ease;
}
:global(.search-suggestions li a:hover),
:global(.search-suggestions li a:focus) {
  background: #F3EFE9;
  outline: none;
}
:global(.search-suggestions .sug-cat) {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #8B6F47;
  flex-shrink: 0;
  border: 1px solid rgba(139,111,71,0.3);
  padding: 2px 8px;
  border-radius: 100px;
  white-space: nowrap;
}
:global(.search-suggestions .sug-title) {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #1C1917;
}
:global(.search-suggestions mark) {
  background: rgba(196,168,130,0.4);
  color: #1C1917;
  border-radius: 2px;
  padding: 0 1px;
}

/* ── Filter bar ── */
.filter-bar {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: var(--header-height);
  z-index: 50;
  padding: 0 24px;
}

.filter-tabs {
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
  max-width: var(--wide-width);
  margin: 0 auto;
}
.filter-tabs::-webkit-scrollbar { display: none; }

.filter-tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 16px 22px;
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 400;
  letter-spacing: 0.04em;
  color: var(--color-text-muted);
  cursor: pointer;
  white-space: nowrap;
  transition: color var(--transition), border-color var(--transition);
  -webkit-tap-highlight-color: transparent;
  min-height: var(--touch-min);
}
.filter-tab:hover { color: var(--color-ink); }
.filter-tab.active {
  color: var(--color-ink);
  border-bottom-color: var(--color-ink);
  font-weight: 500;
}

/* ── Posts grid ── */
.posts-section {
  padding: 56px 24px 80px;
  max-width: var(--wide-width);
  margin: 0 auto;
}

.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px 28px;
}

.post-item { display: none; content-visibility: auto; contain-intrinsic-size: 0 480px; }
.post-item.visible { display: block; }

/* Image */
.post-img-link { display: block; overflow: hidden; }

.post-img-wrap {
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: linear-gradient(90deg, #f0ede8 25%, #e8e4de 50%, #f0ede8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}
.post-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  display: block;
}
.post-item:hover .post-img-wrap img { transform: scale(1.04); }
/* stop shimmer once image loads */
.post-img-wrap:has(img[src]) { animation: none; background: var(--color-surface); }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Broken image fallback */
.post-img-wrap.img-error img { display: none; }
.post-img-wrap.img-error {
  display: flex;
  align-items: center;
  justify-content: center;
}
.post-img-wrap.img-error::after {
  content: '';
  display: block;
  width: 40px;
  height: 40px;
  background: var(--color-border);
  border-radius: 50%;
}

/* Text below image */
.post-info {
  padding: 16px 0 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.post-cat {
  font-family: var(--font-body);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.post-title {
  font-family: var(--font-display);
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  font-weight: 400;
  line-height: 1.3;
  margin: 0;
  color: var(--color-heading);
}
.post-title a {
  color: inherit;
  text-decoration: none;
  transition: color var(--transition);
}
.post-title a:hover { color: var(--color-accent-dark); }

.post-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  color: var(--color-text-faint);
  letter-spacing: 0.03em;
  margin: 0;
}

.no-results {
  text-align: center;
  padding: 80px 0;
  color: var(--color-text-muted);
  font-size: 1rem;
}

/* ── Pagination (MUI-inspired) ── */
.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 56px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border);
  flex-wrap: wrap;
}

/* shared base — full browser reset then rebuild */
.page-arrow,
.page-num {
  all: unset;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  transition: background-color 180ms ease, color 180ms ease;
}

/* Prev / Next chevron buttons */
.page-arrow {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  color: rgba(0,0,0,0.4);
}
.page-arrow:hover:not(:disabled) {
  background-color: rgba(0,0,0,0.06);
  color: rgba(0,0,0,0.87);
}
.page-arrow:disabled {
  color: rgba(0,0,0,0.2);
  cursor: default;
  pointer-events: none;
}

.page-numbers {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
}

/* :global because these are created dynamically via JS — Astro scoping won't reach them */
:global(.page-num) {
  all: unset;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  font-family: var(--font-body);
  font-size: 1.1rem;
  font-weight: 500;
  color: rgba(0,0,0,0.75);
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
  transition: background-color 180ms ease, color 180ms ease;
}
:global(.page-num:hover:not(.active)) {
  background-color: rgba(0,0,0,0.06);
  color: rgba(0,0,0,0.9);
}
:global(.page-num.active) {
  background-color: var(--color-accent-dark);
  color: #fff;
  font-weight: 700;
  animation: page-pop 220ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes page-pop {
  from { transform: scale(0.5); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}

:global(.page-ellipsis) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  font-size: 1rem;
  font-weight: 500;
  color: rgba(0,0,0,0.35);
  pointer-events: none;
  letter-spacing: 0.12em;
  user-select: none;
}

@media (max-width: 480px) {
  :global(.page-num) { width: 36px !important; height: 36px !important; font-size: 0.82rem !important; }
  :global(.page-ellipsis) { width: 28px !important; height: 36px !important; font-size: 0.88rem !important; }
}

/* ── Responsive ── */
@media (max-width: 860px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); gap: 32px 20px; }
}

@media (max-width: 480px) {
  .read-hero-content { padding: 64px 20px 48px; }
  .posts-section { padding: 40px 16px 72px; }
  .posts-grid { grid-template-columns: repeat(2, 1fr); gap: 24px 14px; }
  .filter-tab { padding: 14px 16px; }
  .pagination { gap: 4px; }
  .page-numbers { gap: 4px; }
  .page-arrow { width: 36px; height: 36px; }
}
</style>

<script define:vars={{ POSTS_PER_PAGE }}>
const tabs        = document.querySelectorAll('.filter-tab');
const allItems    = Array.from(document.querySelectorAll('.post-item'));
const noResults   = document.getElementById('no-results');
const searchInput = document.getElementById('post-search');
const clearBtn    = document.getElementById('search-clear');
const prevBtn     = document.getElementById('prev-btn');
const nextBtn     = document.getElementById('next-btn');
const pageNumbers = document.getElementById('page-numbers');
const suggestions = document.getElementById('search-suggestions');

// Build suggestions index from post items
const postIndex = allItems.map(item => ({
  title: item.dataset.title ?? '',
  desc:  item.dataset.desc  ?? '',
  tags:  item.dataset.tags  ?? '',
  cat:   item.dataset.category ?? '',
  slug:  item.dataset.slug  ?? '',
  label: item.querySelector('.post-title a')?.textContent ?? '',
}));

function highlight(text, query) {
  if (!query) return text;
  const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  return text.replace(new RegExp(`(${escaped})`, 'gi'), '<mark>$1</mark>');
}

function showSuggestions(query) {
  if (!suggestions) return;
  const q = query.trim().toLowerCase();
  if (!q) { suggestions.hidden = true; suggestions.innerHTML = ''; return; }

  const matches = postIndex
    .filter(p => p.title.includes(q) || p.desc.includes(q) || p.tags.includes(q))
    .slice(0, 6);

  if (!matches.length) { suggestions.hidden = true; suggestions.innerHTML = ''; return; }

  suggestions.innerHTML = matches.map(p => `
    <li role="option">
      <a href="/blog/${p.slug}">
        <span class="sug-cat">${p.cat}</span>
        <span class="sug-title">${highlight(p.label, query.trim())}</span>
      </a>
    </li>
  `).join('');
  suggestions.hidden = false;
}

function hideSuggestions() {
  if (suggestions) { suggestions.hidden = true; suggestions.innerHTML = ''; }
}

// Close suggestions when clicking outside
document.addEventListener('click', (e) => {
  if (!searchInput?.contains(e.target) && !suggestions?.contains(e.target)) hideSuggestions();
});

let activeCat  = 'All';
let searchQ    = '';
let currentPage = 1;
let filteredItems = [];

function getFilteredItems() {
  return allItems.filter(item => {
    const catMatch  = activeCat === 'All' || item.dataset.category === activeCat;
    const keyword   = searchQ.trim().toLowerCase();
    const textMatch = !keyword ||
      (item.dataset.title  ?? '').includes(keyword) ||
      (item.dataset.desc   ?? '').includes(keyword) ||
      (item.dataset.category ?? '').toLowerCase().includes(keyword);
    return catMatch && textMatch;
  });
}

function renderPage() {
  filteredItems = getFilteredItems();
  const total = filteredItems.length;
  const totalPages = Math.max(1, Math.ceil(total / POSTS_PER_PAGE));
  if (currentPage > totalPages) currentPage = totalPages;

  const start = (currentPage - 1) * POSTS_PER_PAGE;
  const end   = start + POSTS_PER_PAGE;

  // Show/hide items
  allItems.forEach(item => item.classList.remove('visible'));
  filteredItems.slice(start, end).forEach(item => item.classList.add('visible'));

  // No results
  if (noResults) noResults.hidden = total > 0;

  // Pagination controls
  const pagination = document.getElementById('pagination');
  if (pagination) pagination.style.display = totalPages <= 1 && total > 0 ? 'none' : 'flex';

  if (prevBtn) prevBtn.disabled = currentPage <= 1;
  if (nextBtn) nextBtn.disabled = currentPage >= totalPages;

  // Page number buttons
  if (pageNumbers) {
    pageNumbers.innerHTML = '';
    if (totalPages > 1) {
      renderPageNumbers(totalPages);
    }
  }

  // Scroll to top of grid on page change
  const grid = document.getElementById('posts-grid');
  if (grid && currentPage > 1) {
    grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

function renderPageNumbers(totalPages) {
  const isMobile = window.innerWidth <= 480;
  const win = isMobile ? 0 : 1;           // pages shown each side of current
  const fullThreshold = isMobile ? 5 : 7; // show all pages below this count

  const makeDot = () => {
    const span = document.createElement('span');
    span.className = 'page-ellipsis';
    span.textContent = '…';
    pageNumbers.appendChild(span);
  };
  const makeBtn = (n) => {
    const btn = document.createElement('button');
    btn.className = `page-num${n === currentPage ? ' active' : ''}`;
    btn.textContent = n;
    btn.setAttribute('aria-label', `Page ${n}`);
    if (n === currentPage) btn.setAttribute('aria-current', 'page');
    btn.addEventListener('click', () => { currentPage = n; renderPage(); });
    pageNumbers.appendChild(btn);
  };

  if (totalPages <= fullThreshold) {
    for (let i = 1; i <= totalPages; i++) makeBtn(i);
  } else {
    makeBtn(1);
    if (currentPage > 2 + win) makeDot();
    const start = Math.max(2, currentPage - win);
    const end   = Math.min(totalPages - 1, currentPage + win);
    for (let i = start; i <= end; i++) makeBtn(i);
    if (currentPage < totalPages - 1 - win) makeDot();
    makeBtn(totalPages);
  }
}

function setCategory(cat) {
  activeCat = cat;
  currentPage = 1;
  tabs.forEach(t => {
    const isActive = (t.dataset.category ?? 'All') === cat;
    t.classList.toggle('active', isActive);
    t.setAttribute('aria-selected', String(isActive));
  });
  renderPage();
}

// Category tabs
tabs.forEach(tab => {
  tab.addEventListener('click', () => setCategory(tab.dataset.category ?? 'All'));
});

// Prev / Next
prevBtn?.addEventListener('click', () => {
  if (currentPage > 1) { currentPage--; renderPage(); }
});
nextBtn?.addEventListener('click', () => {
  const total = getFilteredItems().length;
  const totalPages = Math.ceil(total / POSTS_PER_PAGE);
  if (currentPage < totalPages) { currentPage++; renderPage(); }
});

// Search
searchInput?.addEventListener('input', () => {
  searchQ = searchInput.value;
  currentPage = 1;
  if (clearBtn) clearBtn.hidden = !searchQ;
  showSuggestions(searchInput.value);
  renderPage();
});

searchInput?.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') hideSuggestions();
});

clearBtn?.addEventListener('click', () => {
  if (searchInput) searchInput.value = '';
  searchQ = '';
  currentPage = 1;
  clearBtn.hidden = true;
  hideSuggestions();
  searchInput?.focus();
  renderPage();
});

// URL category param
const urlCat = new URLSearchParams(window.location.search).get('category');
if (urlCat) {
  setCategory(urlCat);
} else {
  renderPage();
}
</script>
