---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';

const allPosts = await getCollection('blog');
const sorted   = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const categories = ['All', 'Organization', 'Decor', 'Storage', 'Budget Tips'];

const catClass: Record<string, string> = {
  'Organization': 'cat-organization',
  'Decor':        'cat-decor',
  'Storage':      'cat-storage',
  'Budget Tips':  'cat-budget-tips',
};
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title="Blog — SmallSpace Home"
      description="All posts on organization, decor, storage, and budget tips for Canadian apartment renters. Browse by category or start from the top."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main>
      <!-- Editorial hero — centered, two-line serif like Studio McGee -->
      <section class="read-hero">
        <h1 class="read-hero-title">
          Read All<br />
          <em>Organization &amp; Decor</em>
        </h1>
      </section>

      <!-- Keyword search bar -->
      <div class="search-bar-wrap">
        <div class="search-bar-inner">
          <label for="post-search" class="sr-only">Search posts</label>
          <div class="search-field">
            <svg class="search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              type="search"
              id="post-search"
              class="search-input"
              placeholder="Search by keyword — organization, IKEA, budget…"
              autocomplete="off"
              spellcheck="false"
            />
            <button class="search-clear" id="search-clear" aria-label="Clear search" hidden>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Category filter — plain underline tabs -->
      <div class="filter-bar" id="filter-bar">
        <nav class="filter-tabs" role="tablist" aria-label="Filter by category">
          {categories.map(cat => (
            <button
              class={`filter-tab${cat === 'All' ? ' active' : ''}`}
              data-category={cat}
              role="tab"
              aria-selected={cat === 'All' ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </nav>
      </div>

      <!-- Posts grid — full-bleed portrait images -->
      <section class="posts-section">
        <div class="posts-grid" id="posts-grid">
          {sorted.map(post => {
            const date = new Date(post.data.datePublished).toLocaleDateString('en-CA', {
              year: 'numeric', month: 'long', day: 'numeric',
            });
            return (
              <article
                class="post-item"
                data-category={post.data.category}
                data-title={post.data.title.toLowerCase()}
                data-desc={post.data.description.toLowerCase()}
              >
                <a href={`/blog/${post.slug}`} class="post-img-link">
                  <div class="post-img-wrap img-placeholder">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      loading="lazy"
                      width="800"
                      height="1066"
                      onerror="this.style.display='none'"
                    />
                  </div>
                </a>
                <div class="post-info">
                  <span class={`post-cat ${catClass[post.data.category] ?? 'cat-organization'}`}>
                    {post.data.category}
                  </span>
                  <h2 class="post-title">
                    <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                  </h2>
                  <p class="post-meta">
                    <time datetime={post.data.datePublished}>{date}</time>
                    <span aria-hidden="true">·</span>
                    <span>{post.data.readTime} min read</span>
                  </p>
                </div>
              </article>
            );
          })}
        </div>

        <p class="no-results" id="no-results" hidden>
          No posts in this category yet — check back soon!
        </p>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
/* ── Hero ── */
.read-hero {
  text-align: center;
  padding: 80px 24px 56px;
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
}

.read-hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 6vw, 4.2rem);
  font-weight: 400;
  line-height: 1.12;
  color: var(--color-heading);
  margin: 0;
}

.read-hero-title em {
  font-style: italic;
  font-weight: 400;
  color: var(--color-heading);
}

/* ── Search bar ── */
.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

.search-bar-wrap {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  padding: 10px 24px;
}

.search-bar-inner {
  max-width: 560px;
  margin: 0;
}

.search-field {
  display: flex;
  align-items: center;
  gap: 7px;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  padding: 7px 12px;
  transition: border-color var(--transition);
}
.search-field:focus-within { border-color: var(--color-ink); }

.search-icon {
  color: var(--color-text-faint);
  flex-shrink: 0;
  width: 13px;
  height: 13px;
  transition: color var(--transition);
}
.search-field:focus-within .search-icon { color: var(--color-text-muted); }

.search-input {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  font-family: var(--font-body);
  font-size: 0.72rem;
  color: var(--color-ink);
  min-height: 28px;
  -webkit-appearance: none;
  letter-spacing: 0.02em;
}
.search-input::placeholder { color: var(--color-text-faint); font-size: 0.73rem; }
.search-input::-webkit-search-cancel-button { display: none; }

.search-clear {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-faint);
  padding: 2px;
  display: flex;
  align-items: center;
  transition: color var(--transition);
  -webkit-tap-highlight-color: transparent;
}
.search-clear:hover { color: var(--color-ink); }

/* ── Filter bar ── */
.filter-bar {
  background: var(--color-white);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: var(--header-height);
  z-index: 50;
  padding: 0 24px;
}

.filter-tabs {
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
  max-width: var(--wide-width);
  margin: 0 auto;
}
.filter-tabs::-webkit-scrollbar { display: none; }

.filter-tab {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  padding: 16px 22px;
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 400;
  letter-spacing: 0.04em;
  color: var(--color-text-muted);
  cursor: pointer;
  white-space: nowrap;
  transition: color var(--transition), border-color var(--transition);
  -webkit-tap-highlight-color: transparent;
  min-height: var(--touch-min);
}
.filter-tab:hover { color: var(--color-ink); }
.filter-tab.active {
  color: var(--color-ink);
  border-bottom-color: var(--color-ink);
  font-weight: 500;
}

/* ── Posts grid ── */
.posts-section {
  padding: 56px 24px 100px;
  max-width: var(--wide-width);
  margin: 0 auto;
}

.posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px 28px;
}

.post-item.hidden { display: none; }

/* Image — tall portrait, full-bleed */
.post-img-link { display: block; overflow: hidden; }

.post-img-wrap {
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: var(--color-surface);
}
.post-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
  display: block;
}
.post-item:hover .post-img-wrap img { transform: scale(1.04); }

/* Text below image */
.post-info {
  padding: 16px 0 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.post-cat {
  font-family: var(--font-body);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.post-title {
  font-family: var(--font-display);
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  font-weight: 400;
  line-height: 1.3;
  margin: 0;
  color: var(--color-heading);
}
.post-title a {
  color: inherit;
  text-decoration: none;
  transition: color var(--transition);
}
.post-title a:hover { color: var(--color-accent-dark); }

.post-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  color: var(--color-text-faint);
  letter-spacing: 0.03em;
  margin: 0;
}

.no-results {
  text-align: center;
  padding: 80px 0;
  color: var(--color-text-muted);
  font-size: 1rem;
}

/* ── Responsive ── */
@media (max-width: 860px) {
  .posts-grid { grid-template-columns: repeat(2, 1fr); gap: 32px 20px; }
}

@media (max-width: 480px) {
  .read-hero { padding: 56px 20px 40px; }
  .posts-section { padding: 40px 16px 72px; }
  .posts-grid { grid-template-columns: repeat(2, 1fr); gap: 24px 14px; }
  .filter-tab { padding: 14px 16px; }
}
</style>

<script>
const tabs        = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
const items       = document.querySelectorAll<HTMLElement>('.post-item');
const noResults   = document.getElementById('no-results');
const searchInput = document.getElementById('post-search') as HTMLInputElement | null;
const clearBtn    = document.getElementById('search-clear') as HTMLButtonElement | null;

let activeCat = 'All';
let searchQ   = '';

function applyFilters() {
  let visible = 0;
  items.forEach(item => {
    const catMatch  = activeCat === 'All' || item.dataset.category === activeCat;
    const keyword   = searchQ.trim().toLowerCase();
    const textMatch = !keyword ||
      (item.dataset.title  ?? '').includes(keyword) ||
      (item.dataset.desc   ?? '').includes(keyword) ||
      (item.dataset.category ?? '').toLowerCase().includes(keyword);

    const show = catMatch && textMatch;
    item.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  if (noResults) noResults.hidden = visible > 0;
}

function setCategory(cat: string) {
  activeCat = cat;
  tabs.forEach(t => {
    const isActive = (t.dataset.category ?? 'All') === cat;
    t.classList.toggle('active', isActive);
    t.setAttribute('aria-selected', String(isActive));
  });
  applyFilters();
}

/* Category tabs */
tabs.forEach(tab => {
  tab.addEventListener('click', () => setCategory(tab.dataset.category ?? 'All'));
});

/* Read category from URL on page load (e.g. /blog?category=Organization) */
const urlCat = new URLSearchParams(window.location.search).get('category');
if (urlCat) setCategory(urlCat);

/* Keyword search */
searchInput?.addEventListener('input', () => {
  searchQ = searchInput.value;
  if (clearBtn) clearBtn.hidden = !searchQ;
  applyFilters();
});

clearBtn?.addEventListener('click', () => {
  if (searchInput) searchInput.value = '';
  searchQ = '';
  clearBtn.hidden = true;
  searchInput?.focus();
  applyFilters();
});
</script>
