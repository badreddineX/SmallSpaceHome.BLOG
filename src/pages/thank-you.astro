---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Message Sent — SmallSpace Home</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <Header />

    <main class="ty-page">
      <div class="container ty-inner">
        <span class="ty-icon" aria-hidden="true">✓</span>
        <h1 class="ty-h">Message received!</h1>
        <p class="ty-p">
          Thanks for reaching out. I read every message and will reply within 2–3 business days.
        </p>
        <div class="ty-ctas">
          <a href="/" class="btn btn-primary">Back to Homepage</a>
          <a href="/blog" class="btn btn-outline">Read the Blog</a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
.ty-page {
  min-height: 60vh;
  display: flex;
  align-items: center;
  padding: 80px 0;
  background: var(--color-bg);
}
.ty-inner {
  text-align: center;
  max-width: 480px;
  margin: 0 auto;
}
.ty-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--color-surface);
  border: 1.5px solid var(--color-border);
  font-size: 1.6rem;
  color: var(--color-primary-dark);
  margin-bottom: 24px;
}
.ty-h {
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  margin: 0 0 16px;
  color: var(--color-heading);
}
.ty-p {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  line-height: 1.8;
  margin-bottom: 36px;
}
.ty-ctas {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}
</style>
