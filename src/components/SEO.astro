---
interface Props {
  title: string;
  description: string;
  slug?: string;
  image?: string;
  datePublished?: string;
  dateModified?: string;
  authorName?: string;
  type?: 'website' | 'article';
  faqs?: { q: string; a: string }[];
}

const {
  title,
  description,
  slug,
  image = '/images/about-hero-apartment.jpg',
  datePublished,
  dateModified,
  authorName = 'Badreddine Br',
  type = 'website',
  faqs = [],
} = Astro.props;

const siteUrl   = 'https://smallspacehome.ca';
const fullUrl   = slug ? `${siteUrl}/blog/${slug}` : siteUrl;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
const fullTitle = `${title} | SmallSpace Home`;

const isArticle    = type === 'article';
const hasPublished = isArticle && Boolean(datePublished);
const hasModified  = isArticle && Boolean(dateModified);
const modOrPub     = dateModified || datePublished || '';

const articleJsonLd = isArticle ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "image": fullImage,
  "datePublished": datePublished,
  "dateModified": modOrPub,
  "author": {
    "@type": "Person",
    "name": authorName,
    "url": `${siteUrl}/about`
  },
  "publisher": {
    "@type": "Organization",
    "name": "SmallSpace Home",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": fullUrl
  }
}) : null;

const faqJsonLd = faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a.replace(/<[^>]+>/g, '')
    }
  }))
}) : null;
---

<!-- Primary -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={fullUrl} />

<!-- Open Graph -->
<meta property="og:type"         content={type} />
<meta property="og:title"        content={fullTitle} />
<meta property="og:description"  content={description} />
<meta property="og:url"          content={fullUrl} />
<meta property="og:image"   content={fullImage} />
<meta property="og:locale"  content="en_CA" />
<meta property="og:site_name"    content="SmallSpace Home" />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={fullImage} />

<!-- Article meta (only rendered when type="article") -->
{hasPublished && <meta property="article:published_time" content={datePublished} />}
{hasModified  && <meta property="article:modified_time"  content={dateModified} />}
{isArticle    && <meta property="article:author"         content={authorName} />}

<!-- Article JSON-LD -->
{isArticle && articleJsonLd && <script type="application/ld+json" set:html={articleJsonLd} />}

<!-- FAQ JSON-LD -->
{faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}

