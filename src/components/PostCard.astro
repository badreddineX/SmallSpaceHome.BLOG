---
interface Props {
  title: string;
  slug: string;
  description: string;
  image: string;
  category: string;
  datePublished: string;
  readTime: number;
  size?: 'default' | 'featured';
}

const {
  title, slug, description, image,
  category, datePublished, readTime,
  size = 'default',
} = Astro.props;

const formattedDate = new Date(datePublished).toLocaleDateString('en-CA', {
  year: 'numeric', month: 'short', day: 'numeric',
});

const catClass: Record<string, string> = {
  'Organization': 'cat-organization',
  'Decor':        'cat-decor',
  'Storage':      'cat-storage',
  'Budget Tips':  'cat-budget-tips',
};
---

<article class={`post-card${size === 'featured' ? ' post-card--featured' : ''}`}>

  <a href={`/blog/${slug}`} class="card-img-link" tabindex="-1" aria-hidden="true">
    <div class="card-img-wrap img-placeholder">
      <img
        src={image}
        alt={title}
        loading="lazy"
        width="800" height="600"
        onerror="this.style.display='none'"
      />
    </div>
  </a>

  <div class="card-body">
    <span class={`category-pill ${catClass[category] ?? 'cat-organization'}`}>
      {category}
    </span>

    <h3 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>

    <p class="card-excerpt">{description}</p>

    <div class="card-meta">
      <time datetime={datePublished}>{formattedDate}</time>
      <span aria-hidden="true">·</span>
      <span>{readTime} min read</span>
    </div>
  </div>

</article>

<style>
.post-card {
  display: flex;
  flex-direction: column;
  background: transparent;
}

.card-img-link { display: block; overflow: hidden; }

.card-img-wrap {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: var(--color-surface);
  min-height: 180px;
}
.card-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.55s ease;
  border-radius: 0;
}
.post-card:hover .card-img-wrap img { transform: scale(1.04); }

.card-body {
  padding: 12px 0 0;     /* tighter on mobile */
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}

.category-pill { align-self: flex-start; }

.card-title {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 700;
  font-style: italic;
  line-height: 1.3;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-title a {
  color: var(--color-heading);
  text-decoration: none;
  transition: color var(--transition);
}
.card-title a:hover { color: var(--color-accent-dark); }

.card-excerpt {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.7;
  font-weight: 300;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.7rem;
  color: var(--color-text-faint);
  letter-spacing: 0.04em;
  margin-top: auto;
  padding-top: 4px;
}

.post-card--featured .card-img-wrap { aspect-ratio: 3 / 4; }
.post-card--featured .card-title    { font-size: 1.15rem; }
</style>
