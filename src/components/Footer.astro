---
import Analytics from '@vercel/analytics/astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">

  <!-- Top band -->
  <div class="footer-top">
    <div class="container footer-top-inner">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label="SmallSpace Home — homepage">
          <span class="footer-logo-img-wrap">
            <img
              src="/images/logo.png"
              alt=""
              class="footer-logo-img"
              width="120"
              height="40"
              aria-hidden="true"
            />
          </span>
          <span class="footer-logo-text">SmallSpace Home</span>
        </a>
        <p class="footer-tagline">
          Organization and decor ideas for Canadian apartment renters.
          Renter-friendly. Budget-conscious. Actually useful.
        </p>

        <!-- Social media icons -->
        <div class="footer-social" aria-label="Follow us on social media">
          <a
            href="https://pinterest.ca"
            class="social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Pinterest"
          >
            <!-- Pinterest P icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
            </svg>
          </a>

          <a
            href="https://facebook.com"
            class="social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
          >
            <!-- Facebook f icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>

          <a
            href="https://instagram.com"
            class="social-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
          >
            <!-- Instagram icon -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <span class="footer-col-label">Read</span>
          <a href="/blog">All Posts</a>
          <a href="/blog?category=Organization">Organization</a>
          <a href="/blog?category=Decor">Decor</a>
          <a href="/blog?category=Storage">Storage</a>
          <a href="/blog?category=Budget+Tips">Budget Tips</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-label">Site</span>
          <a href="/about">About</a>
          <a href="/about#contact">Contact</a>
          <a href="/privacy-policy">Privacy Policy</a>
          <a href="/terms">Terms of Use</a>
        </div>
      </nav>
    </div>
  </div>

  <!-- Newsletter -->
  <div class="footer-newsletter">
    <div class="container newsletter-inner">
      <div class="newsletter-text">
        <p class="newsletter-label">Stay in the loop</p>
        <p class="newsletter-desc">New ideas for small Canadian apartments — straight to your inbox, no spam.</p>
      </div>
      <form
        class="newsletter-form"
        action="https://formsubmit.co/badreddinekx122@gmail.com"
        method="POST"
      >
        <input type="hidden" name="_subject" value="New SmallSpaceHome Newsletter Signup" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="text" name="_honey" style="display:none" />
        <div class="newsletter-field">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="newsletter-input"
            aria-label="Email address"
          />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p class="footer-copy">© {year} SmallSpace Home &nbsp;·&nbsp; All prices in CAD</p>
    </div>
  </div>

</footer>

<style>
.site-footer {
  background: var(--color-dark);
  margin-top: 0;
}

/* ── Top ── */
.footer-top {
  padding: 72px 0 64px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}

.footer-top-inner {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 64px;
}

.footer-logo {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
  text-decoration: none;
  transition: opacity var(--transition);
}
.footer-logo:hover { opacity: 0.8; }

.footer-logo-img-wrap {
  display: flex;
  align-items: center;
  background: #FAFAF7;
  padding: 3px 6px;
  border-radius: 2px;
  flex-shrink: 0;
}
.footer-logo-img {
  height: 44px;
  width: auto;
  display: block;
  object-fit: contain;
}
.footer-logo-text {
  font-family: var(--font-body);
  font-weight: 300;
  font-size: 0.68rem;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.82);
  white-space: nowrap;
}

.footer-tagline {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.4);
  max-width: 260px;
  line-height: 1.75;
  font-weight: 300;
  margin: 0 0 24px;
}

/* ── Social icons ── */
.footer-social {
  display: flex;
  align-items: center;
  gap: 12px;
}

.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 50%;
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  transition: border-color var(--transition), color var(--transition), background var(--transition);
  -webkit-tap-highlight-color: transparent;
  flex-shrink: 0;
}
.social-link:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: rgba(196,168,130,0.08);
}

/* Pinterest red on hover */
.social-link[aria-label="Pinterest"]:hover {
  border-color: #E60023;
  color: #E60023;
  background: rgba(230,0,35,0.06);
}
/* Facebook blue on hover */
.social-link[aria-label="Facebook"]:hover {
  border-color: #1877F2;
  color: #1877F2;
  background: rgba(24,119,242,0.06);
}
/* Instagram gradient on hover */
.social-link[aria-label="Instagram"]:hover {
  border-color: #E1306C;
  color: #E1306C;
  background: rgba(225,48,108,0.06);
}

.footer-nav {
  display: flex;
  gap: 64px;
  flex-shrink: 0;
}

.footer-col {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer-col-label {
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 4px;
}

.footer-col a {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  font-weight: 300;
  transition: color var(--transition);
}
.footer-col a:hover { color: rgba(255,255,255,0.9); }

/* ── Newsletter ── */
.footer-newsletter {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 48px 0;
}
.newsletter-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
}
.newsletter-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin: 0 0 6px;
}
.newsletter-desc {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.45);
  font-weight: 300;
  line-height: 1.6;
  margin: 0;
  max-width: 340px;
}
.newsletter-form { flex-shrink: 0; }
.newsletter-field {
  display: flex;
  align-items: stretch;
  gap: 0;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 3px;
  overflow: hidden;
}
.newsletter-input {
  background: rgba(255,255,255,0.05);
  border: none;
  outline: none;
  padding: 12px 18px;
  font-family: var(--font-body);
  font-size: 0.88rem;
  color: rgba(255,255,255,0.85);
  width: 240px;
}
.newsletter-input::placeholder { color: rgba(255,255,255,0.3); }
.newsletter-input:focus { background: rgba(255,255,255,0.08); }
.newsletter-btn {
  background: var(--color-accent-dark);
  color: #fff;
  border: none;
  padding: 12px 22px;
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.2s ease;
  white-space: nowrap;
}
.newsletter-btn:hover { background: #7a6040; }

@media (max-width: 640px) {
  .newsletter-inner { flex-direction: column; align-items: flex-start; gap: 24px; }
  .newsletter-input { width: 100%; }
  .newsletter-field { width: 100%; }
}

/* ── Bottom ── */
.footer-bottom {
  padding: 22px 0;
}

.footer-bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}

.footer-disclosure {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.3);
  max-width: 540px;
  line-height: 1.6;
  font-weight: 300;
  margin: 0;
}

.footer-copy {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.3);
  white-space: nowrap;
  font-weight: 300;
  margin: 0;
}

@media (max-width: 768px) {
  .footer-top-inner    { flex-direction: column; gap: 40px; }
  .footer-bottom-inner { flex-direction: column; align-items: flex-start; gap: 10px; }
  .footer-tagline      { max-width: 100%; }
}
</style>

<Analytics />

<!-- ── Cookie Consent Banner ── -->
<div class="cookie-banner" id="cookie-banner" aria-live="polite" aria-label="Cookie consent">
  <p class="cookie-text">
    We use cookies to improve your experience. By continuing to browse, you agree to our
    <a href="/privacy-policy" class="cookie-link">Privacy Policy</a>.
  </p>
  <div class="cookie-actions">
    <button class="cookie-btn cookie-accept" id="cookie-accept">Accept</button>
    <button class="cookie-btn cookie-decline" id="cookie-decline">Decline</button>
  </div>
</div>

<style>
.cookie-banner {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  background: var(--color-ink, #1C1917);
  color: rgba(255,255,255,0.88);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 6px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  width: calc(100% - 32px);
  max-width: 680px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.28);
  animation: cookie-slide-up 0.3s ease both;
}

.cookie-banner.hidden {
  display: none;
}

@keyframes cookie-slide-up {
  from { opacity: 0; transform: translateX(-50%) translateY(16px); }
  to   { opacity: 1; transform: translateX(-50%) translateY(0); }
}

.cookie-text {
  flex: 1;
  font-size: 0.82rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.75);
  margin: 0;
  min-width: 200px;
}

.cookie-link {
  color: var(--color-accent, #C4A882);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.cookie-link:hover { color: #fff; }

.cookie-actions {
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}

.cookie-btn {
  border: none;
  border-radius: 3px;
  padding: 8px 18px;
  font-family: inherit;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease;
  white-space: nowrap;
  -webkit-tap-highlight-color: transparent;
}

.cookie-accept {
  background: var(--color-accent-dark, #8B6F47);
  color: #fff;
}
.cookie-accept:hover { background: #7a6040; }

.cookie-decline {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.6);
  border: 1px solid rgba(255,255,255,0.15);
}
.cookie-decline:hover { background: rgba(255,255,255,0.14); color: #fff; }

@media (max-width: 480px) {
  .cookie-banner { bottom: 16px; padding: 14px 16px; gap: 12px; }
  .cookie-text   { font-size: 0.78rem; }
}
</style>

<script>
(function () {
  const banner = document.getElementById('cookie-banner');
  if (!banner) return;

  // Don't show if already answered
  if (localStorage.getItem('cookie-consent')) {
    banner.classList.add('hidden');
    return;
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');
    banner.classList.add('hidden');
  });

  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'declined');
    banner.classList.add('hidden');
  });
})();
</script>
