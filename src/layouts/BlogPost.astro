---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import PostCard from '../components/PostCard.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  datePublished: string;
  dateModified: string;
  author: string;
  category: string;
  readTime: number;
  tags: string[];
  faqs?: { q: string; a: string }[];
  related?: { slug: string; data: { title: string; category: string; readTime: number } }[];
}

const {
  title,
  description,
  slug,
  image,
  datePublished,
  dateModified,
  author,
  category,
  readTime,
  tags,
  faqs = [],
  related = [],
} = Astro.props;

const formattedDate = new Date(datePublished).toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const catClass: Record<string, string> = {
  'Organization': 'cat-organization',
  'Decor':        'cat-decor',
  'Storage':      'cat-storage',
  'Budget Tips':  'cat-budget-tips',
};
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      slug={slug}
      image={image}
      datePublished={datePublished}
      dateModified={dateModified}
      authorName={author}
      type="article"
    />
  </head>
  <body>
    <Header />

    <main>

      <div class="post-wrap container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{category}</span>
        </nav>

        <!-- Two-column layout -->
        <div class="post-layout">

          <!-- ── MAIN CONTENT ── -->
          <article class="post-main">

            <!-- Category label -->
            <span class={`post-eyebrow ${catClass[category] ?? 'cat-organization'}`}>
              {category}
            </span>

            <!-- Title -->
            <h1 class="post-title">{title}</h1>

            <!-- Author + date -->
            <div class="post-meta">
              <span class="post-author">{author}</span>
              <span class="post-dot" aria-hidden="true">·</span>
              <time datetime={datePublished}>{formattedDate}</time>
              <span class="post-dot" aria-hidden="true">·</span>
              <span>{readTime} min read</span>
            </div>

            <!-- Hero image -->
            <div class="post-hero">
              <img
                src={image}
                alt={title}
                class="post-hero-img"
                width="1200"
                height="675"
                loading="eager"
                onerror="this.style.display='none'; this.parentElement.classList.add('img-placeholder');"
              />
            </div>

            <!-- Article body -->
            <div class="post-body">
              <slot />
            </div>

            <!-- FAQ -->
            {faqs.length > 0 && <FAQ questions={faqs} />}

            <!-- Inline continue-reading links after FAQ -->
            {related.length > 0 && (
              <div class="inline-related">
                <p class="inline-related-label">Continue reading</p>
                <ul class="inline-related-list">
                  {related.slice(0, 2).map(p => (
                    <li>
                      <a href={`/blog/${p.slug}`} class="inline-related-link">
                        <span class="inline-related-cat">{p.data.category}</span>
                        <span class="inline-related-title">{p.data.title}</span>
                        <span class="inline-related-meta">{p.data.readTime} min read →</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Author bio -->
            <div class="author-bio">
              <img
                src="/images/author-sarah.jpg"
                alt={author}
                class="author-avatar"
                width="56"
                height="56"
                loading="lazy"
              />
              <div class="author-info">
                <p class="author-name">{author}</p>
                <p class="author-desc">Apartment renter in Toronto, obsessed with making small spaces feel bigger. I share honest, budget-friendly ideas that actually work in Canadian apartments.</p>
              </div>
            </div>

            <!-- Tags -->
            {tags.length > 0 && (
              <div class="post-tags">
                {tags.map(tag => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )}

          </article>

          <!-- ── SIDEBAR ── -->
          <aside class="post-sidebar" aria-label="Article sidebar">

            <!-- In this article (TOC) -->
            <div class="sidebar-toc" id="sidebar-toc">
              <p class="sidebar-toc-heading">In this article</p>
              <ol class="sidebar-toc-list" id="sidebar-toc-list"></ol>
            </div>

            <!-- CTA box -->
            <div class="sidebar-cta">
              <p class="sidebar-cta-label">More ideas</p>
              <p class="sidebar-cta-text">Browse all organization tips, decor ideas, and storage solutions for Canadian apartments.</p>
              <a href="/blog" class="btn btn-primary sidebar-cta-btn">Browse All Posts</a>
            </div>

          </aside>

        </div>
      </div>

      <!-- Related posts -->
      {related.length > 0 && (
        <section class="related-section">
          <div class="container">
            <p class="section-label">Keep reading</p>
            <h2 class="related-heading">You might also like</h2>
            <div class="related-grid">
              {related.map(post => (
                <PostCard
                  title={post.data.title}
                  slug={post.slug}
                  description={post.data.description}
                  image={post.data.image}
                  category={post.data.category}
                  datePublished={post.data.datePublished}
                  readTime={post.data.readTime}
                />
              ))}
            </div>
          </div>
        </section>
      )}

    </main>

    <Footer />
  </body>
</html>

<style>
/* ── Breadcrumb ── */
.post-wrap { padding-top: 28px; padding-bottom: 80px; }

.breadcrumb {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  color: var(--color-text-faint);
  margin-bottom: 32px;
}
.breadcrumb a { color: var(--color-text-faint); }
.breadcrumb a:hover { color: var(--color-ink); }

/* ── Two-column layout ── */
.post-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 64px;
  align-items: start;
}

/* ── Main content ── */
.post-main { min-width: 0; }

.post-eyebrow {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.post-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 400;
  line-height: 1.15;
  color: var(--color-heading);
  margin: 0 0 16px;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  color: var(--color-text-muted);
  margin-bottom: 28px;
}
.post-dot { color: var(--color-text-faint); }
.post-author { font-weight: 500; color: var(--color-ink); }

/* Hero image */
.post-hero {
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  margin-bottom: 40px;
  background: var(--color-surface);
}
.post-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Post body */
.post-body { margin-bottom: 48px; }
.post-body :global(h2) {
  font-size: clamp(1.2rem, 2.5vw, 1.5rem);
  margin-top: 2.4rem;
  margin-bottom: 0.8rem;
  color: var(--color-heading);
}
.post-body :global(h3) {
  font-size: clamp(1rem, 2vw, 1.15rem);
  margin-top: 1.8rem;
  margin-bottom: 0.6rem;
}
.post-body :global(p) { line-height: 1.85; margin-bottom: 1.4rem; }
.post-body :global(ul),
.post-body :global(ol) { margin-bottom: 1.4rem; padding-left: 1.4rem; }
.post-body :global(li) { margin-bottom: 0.4rem; line-height: 1.7; }
.post-body :global(strong) { font-weight: 600; color: var(--color-ink); }
.post-body :global(a) {
  color: var(--color-accent-dark);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.post-body :global(img) {
  width: 100%;
  height: auto;
  display: block;
  margin: 2.4rem 0;
  aspect-ratio: 16 / 9;
  object-fit: cover;
}
.post-body :global(figure) {
  margin: 2.4rem 0;
}
.post-body :global(figure img) {
  margin: 0;
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
}
.post-body :global(figcaption) {
  font-size: 0.75rem;
  color: var(--color-text-faint);
  text-align: center;
  margin-top: 8px;
  font-style: italic;
}
.post-body :global(table) {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9rem;
  margin: 1.6rem 0;
}
.post-body :global(th) {
  background: var(--color-surface);
  padding: 10px 14px;
  text-align: left;
  font-weight: 600;
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  border-bottom: 2px solid var(--color-border);
}
.post-body :global(td) {
  padding: 10px 14px;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text);
}
.post-body :global(tr:last-child td) { border-bottom: none; }

/* Author bio */
.author-bio {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  padding: 24px;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  margin: 40px 0 28px;
}
.author-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  flex-shrink: 0;
  object-fit: cover;
  object-position: center top;
}
.author-name {
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--color-heading);
  margin-bottom: 4px;
}
.author-desc {
  font-size: 0.83rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
}

/* Tags */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}
.post-tag {
  padding: 4px 12px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  font-size: 0.72rem;
  color: var(--color-text-muted);
  letter-spacing: 0.04em;
}

/* ── Sidebar ── */
.post-sidebar {
  position: sticky;
  top: calc(var(--header-height) + 24px);
  display: flex;
  flex-direction: column;
  gap: 32px;
}

/* TOC */
.sidebar-toc { border-top: 2px solid var(--color-ink); padding-top: 16px; }

.sidebar-toc-heading {
  font-family: var(--font-body);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-ink);
  margin-bottom: 16px;
}

.sidebar-toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-toc-list li a {
  display: block;
  font-size: 0.85rem;
  color: var(--color-text-muted);
  text-decoration: none;
  padding: 6px 0;
  border-bottom: 1px solid var(--color-border-light);
  line-height: 1.4;
  transition: color var(--transition);
}
.sidebar-toc-list li:last-child a { border-bottom: none; }
.sidebar-toc-list li a:hover { color: var(--color-ink); }
.sidebar-toc-list li a.toc-active {
  color: var(--color-ink);
  font-weight: 500;
}

/* Sidebar CTA */
.sidebar-cta {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  padding: 24px;
}
.sidebar-cta-label {
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  margin-bottom: 8px;
}
.sidebar-cta-text {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.7;
  margin-bottom: 16px;
}
.sidebar-cta-btn {
  width: 100%;
  justify-content: center;
  font-size: 0.65rem;
  min-height: 42px;
  padding: 10px 20px;
}

/* ── Inline continue-reading ── */
.inline-related {
  margin: 32px 0;
  padding: 24px;
  background: var(--color-surface);
  border-left: 3px solid var(--color-ink);
}

.inline-related-label {
  font-family: var(--font-body);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: 14px;
}

.inline-related-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.inline-related-link {
  display: flex;
  align-items: baseline;
  gap: 10px;
  text-decoration: none;
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border);
  transition: color var(--transition);
}
.inline-related-list li:last-child .inline-related-link { border-bottom: none; padding-bottom: 0; }
.inline-related-link:hover .inline-related-title { color: var(--color-accent-dark); }

.inline-related-cat {
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  white-space: nowrap;
  flex-shrink: 0;
}

.inline-related-title {
  font-family: var(--font-display);
  font-size: 0.95rem;
  color: var(--color-heading);
  flex: 1;
  transition: color var(--transition);
  line-height: 1.3;
}

.inline-related-meta {
  font-size: 0.7rem;
  color: var(--color-text-faint);
  white-space: nowrap;
  flex-shrink: 0;
}

/* ── Related posts ── */
.related-section {
  border-top: 1px solid var(--color-border);
  padding: 64px 0 80px;
}
.related-heading {
  font-size: clamp(1.3rem, 3vw, 1.8rem);
  margin-top: 8px;
  margin-bottom: 32px;
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}

/* ── Mobile — collapse sidebar ── */
@media (max-width: 900px) {
  .post-layout { grid-template-columns: 1fr; gap: 0; }
  .post-sidebar { position: static; }
  .sidebar-toc { display: none; }
  .sidebar-cta { margin-top: 40px; }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
  .related-grid > :last-child { display: none; }
}

@media (max-width: 560px) {
  .post-wrap { padding-top: 20px; padding-bottom: 48px; }
  .related-grid { grid-template-columns: 1fr; }
  .related-grid > :last-child { display: block; }
}
</style>

<script>
/* Build sidebar TOC from H2 headings */
const headings  = document.querySelectorAll<HTMLHeadingElement>('.post-body h2');
const tocList   = document.getElementById('sidebar-toc-list');
const sidebarToc = document.getElementById('sidebar-toc');

if (headings.length < 2) {
  sidebarToc?.remove();
} else {
  headings.forEach((h, i) => {
    if (!h.id) h.id = `section-${i}`;
    const li = document.createElement('li');
    const a  = document.createElement('a');
    a.href        = `#${h.id}`;
    a.textContent = h.textContent;
    li.appendChild(a);
    tocList?.appendChild(li);
  });

  /* Highlight active section on scroll */
  const links = tocList?.querySelectorAll<HTMLAnchorElement>('a') ?? [];
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      const id  = entry.target.id;
      const link = tocList?.querySelector<HTMLAnchorElement>(`a[href="#${id}"]`);
      if (entry.isIntersecting) {
        links.forEach(l => l.classList.remove('toc-active'));
        link?.classList.add('toc-active');
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  headings.forEach(h => observer.observe(h));
}
</script>
