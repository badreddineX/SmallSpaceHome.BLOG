---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  datePublished: string;
  dateModified: string;
  author: string;
  category: string;
  readTime: number;
  tags: string[];
  faqs?: { q: string; a: string }[];
  related?: { slug: string; data: { title: string; category: string; readTime: number; description: string; image: string; datePublished: string } }[];
}

const {
  title,
  description,
  slug,
  image,
  datePublished,
  dateModified,
  author,
  category,
  readTime,
  tags,
  faqs = [],
  related = [],
} = Astro.props;

const formattedDate = new Date(datePublished).toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const catClass: Record<string, string> = {
  'Organization': 'cat-organization',
  'Decor':        'cat-decor',
  'Storage':      'cat-storage',
  'Budget Tips':  'cat-budget-tips',
};
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      slug={slug}
      image={image}
      datePublished={datePublished}
      dateModified={dateModified}
      authorName={author}
      type="article"
      faqs={faqs}
    />
  </head>
  <body>
    <!-- Reading progress bar -->
    <div class="read-progress" id="read-progress" role="progressbar" aria-label="Reading progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>

    <Header />

    <main>

      <!-- ① FULL-BLEED HERO IMAGE -->
      <div class="post-hero-wrap">
        <img
          src={image}
          alt={title}
          class="post-hero-img"
          width="1600"
          height="900"
          loading="eager"
          onerror="this.parentElement.classList.add('hero-fallback')"
        />
        <div class="post-hero-scrim"></div>
      </div>

      <!-- ② POST HEADER — centered below hero -->
      <header class="post-header">
        <div class="post-header-inner">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">›</span>
            <a href="/blog">Blog</a>
            <span aria-hidden="true">›</span>
            <span aria-current="page">{category}</span>
          </nav>

          <span class={`post-eyebrow ${catClass[category] ?? 'cat-organization'}`}>{category}</span>
          <h1 class="post-title">{title}</h1>
          <p class="post-description">{description}</p>

          <div class="post-meta">
            <span class="meta-item">
              <span class="meta-label">Date :</span>
              <time datetime={datePublished}>{formattedDate}</time>
            </span>
            <span class="meta-item">
              <span class="meta-label">Category :</span>
              <span>{category}</span>
            </span>
            <span class="meta-item">
              <span class="meta-label">Read</span>
              <span>{readTime} min</span>
            </span>
          </div>
        </div>
      </header>

      <!-- ③ ARTICLE + SIDEBAR -->
      <div class="post-wrap">
        <div class="post-layout">

          <!-- MAIN -->
          <article class="post-main">

            <div class="post-body">
              <slot />
            </div>

            {faqs.length > 0 && <FAQ questions={faqs} />}

            <!-- Continue reading -->
            {related.length > 0 && (
              <div class="inline-related">
                <p class="inline-related-label">Continue reading</p>
                <ul class="inline-related-list">
                  {related.slice(0, 2).map(p => (
                    <li>
                      <a href={`/blog/${p.slug}`} class="inline-related-link">
                        <div class="ilr-left">
                          <span class="ilr-cat">{p.data.category}</span>
                          <span class="ilr-title">{p.data.title}</span>
                        </div>
                        <span class="ilr-arrow">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Author bio -->
            <div class="author-bio">
              <div class="author-avatar-wrap">
                <div class="author-avatar-circle">
                  <span class="author-initials">BB</span>
                </div>
              </div>
              <div class="author-info">
                <p class="author-name">{author}</p>
                <p class="author-desc">Renting a 510 sq ft apartment in Toronto for over three years. Every tip on this site has been tested in a real Canadian rental — no drilling, no staged perfection, no sponsored fluff. <a href="/about" class="author-bio-link">Read the full story →</a></p>
              </div>
            </div>

            <!-- Tags -->
            {tags.length > 0 && (
              <div class="post-tags">
                {tags.map(tag => (
                  <a class="post-tag" href={`/blog?tag=${encodeURIComponent(tag)}`}>{tag}</a>
                ))}
              </div>
            )}

          </article>

          <!-- SIDEBAR -->
          <aside class="post-sidebar" aria-label="Article sidebar">
            <div class="sidebar-toc toc-widget" id="sidebar-toc">
              <div class="toc-widget__header" id="toc-header">
                <h2 class="toc-widget__header-title">Table of Contents</h2>
                <button type="button" class="toc-widget__toggle-button toc-widget__toggle-button--collapse" aria-label="Close table of contents">
                  <svg viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M240.971 130.524l194.343 194.343c9.373 9.373 9.373 24.569 0 33.941l-22.667 22.667c-9.357 9.357-24.522 9.375-33.901.04L224 227.495 69.255 381.516c-9.379 9.335-24.544 9.317-33.901-.04l-22.667-22.667c-9.373-9.373-9.373-24.569 0-33.941L207.03 130.525c9.372-9.373 24.568-9.373 33.941-.001z"/></svg>
                </button>
                <button type="button" class="toc-widget__toggle-button toc-widget__toggle-button--expand" aria-label="Open table of contents">
                  <svg viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M207.029 381.476L12.686 187.132c-9.373-9.373-9.373-24.569 0-33.941l22.667-22.667c9.357-9.357 24.522-9.375 33.901-.04L224 284.505l154.745-154.021c9.379-9.335 24.544-9.317 33.901.04l22.667 22.667c9.373 9.373 9.373 24.569 0 33.941L240.971 381.476c-9.373 9.372-24.569 9.372-33.942 0z"/></svg>
                </button>
              </div>
              <div class="toc-widget__body" id="toc-body">
                <ol class="toc-widget__list" id="sidebar-toc-list"></ol>
              </div>
            </div>
            <div class="sidebar-cta">
              <p class="sidebar-cta-label">More ideas</p>
              <p class="sidebar-cta-text">Browse all organization tips, decor ideas, and storage solutions for Canadian apartments.</p>
              <a href="/blog" class="btn btn-primary sidebar-cta-btn">Browse All Posts</a>
            </div>
          </aside>

        </div>
      </div>

      <!-- ④ RELATED POSTS -->
      {related.length > 0 && (
        <section class="related-section">
          <div class="container">
            <h2 class="related-heading">Related posts</h2>
            <div class="related-grid">
              {related.map(post => {
                const relDate = new Date(post.data.datePublished).toLocaleDateString('en-CA', {
                  day: 'numeric', month: 'short', year: 'numeric',
                });
                return (
                  <a href={`/blog/${post.slug}`} class="rel-card">
                    <div class="rel-card-img-wrap">
                      <img
                        src={post.data.image}
                        alt={post.data.title}
                        loading="lazy"
                        width="800"
                        height="450"
                        onerror="this.parentElement.style.background='var(--color-surface)'"
                      />
                    </div>
                    <div class="rel-card-body">
                      <span class="rel-card-date">{relDate}</span>
                      <h3 class="rel-card-title">{post.data.title}</h3>
                      <p class="rel-card-desc">{post.data.description}</p>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      )}

    </main>

    <Footer />
  </body>
</html>

<style>
/* ── Reading progress bar ── */
.read-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 0%;
  height: 3px;
  background: var(--color-accent-dark);
  z-index: 9999;
  transition: width 0.1s linear;
  border-radius: 0 2px 2px 0;
}

/* ══════════════════════════════════════════
   ① HERO
══════════════════════════════════════════ */
.post-hero-wrap {
  position: relative;
  width: 100%;
  height: 68vh;
  min-height: 360px;
  max-height: 700px;
  overflow: hidden;
  background: var(--color-surface);
}
.post-hero-wrap.hero-fallback {
  background: var(--color-surface);
  height: 280px;
}
.post-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 40%;
  display: block;
}
.post-hero-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 50%,
    rgba(250,250,247,0.18) 80%,
    rgba(250,250,247,0.55) 100%
  );
}

/* ══════════════════════════════════════════
   ② POST HEADER
══════════════════════════════════════════ */
.post-header {
  padding: 48px 24px 40px;
  border-bottom: 1px solid var(--color-border);
  overflow-x: hidden;
}
.post-header-inner {
  max-width: 760px;
  margin: 0 auto;
}
.breadcrumb {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  color: var(--color-text-faint);
  margin-bottom: 24px;
}
.breadcrumb a { color: var(--color-text-faint); text-decoration: none; transition: color var(--transition); }
.breadcrumb a:hover { color: var(--color-ink); }

.post-eyebrow {
  display: inline-block;
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 18px;
}
.post-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 5vw, 3.2rem);
  font-weight: 700;
  font-style: italic;
  line-height: 1.12;
  color: var(--color-ink);
  margin: 0 0 20px;
  letter-spacing: -0.02em;
  overflow-wrap: break-word;
  word-break: break-word;
}
.post-description {
  font-size: 1.1rem;
  line-height: 1.7;
  color: var(--color-text-muted);
  margin: 0 0 28px;
  font-weight: 300;
}
.post-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 24px;
  font-size: 0.85rem;
  color: var(--color-text);
  border-top: 1px solid var(--color-border);
  padding-top: 20px;
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
}
.meta-label {
  font-weight: 700;
  color: var(--color-ink);
}

/* ══════════════════════════════════════════
   ③ ARTICLE LAYOUT
══════════════════════════════════════════ */
.post-wrap {
  max-width: 1160px;
  margin: 0 auto;
  padding: 56px 24px 80px;
}
.post-layout {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 72px;
  align-items: start;
}
.post-main { min-width: 0; overflow-x: hidden; }

/* ── Body typography ── */
.post-body {
  margin-bottom: 56px;
  overflow-wrap: break-word;
  word-break: break-word;
}

.post-body :global(p) {
  font-size: 1.05rem;
  line-height: 1.9;
  color: var(--color-text);
  margin: 0 0 1.6rem;
}
.post-body :global(p:first-child) {
  font-size: 1.15rem;
  color: var(--color-ink);
  line-height: 1.85;
}
.post-body :global(h2) {
  font-family: var(--font-display);
  font-size: clamp(1.35rem, 2.8vw, 1.65rem);
  font-weight: 700;
  font-style: italic;
  color: var(--color-ink);
  margin: 3rem 0 1rem;
  line-height: 1.25;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12px;
  max-width: 100%;
}
.post-body :global(.h2-num) {
  font-family: var(--font-display);
  font-size: clamp(1rem, 2vw, 1.2rem);
  font-weight: 400;
  font-style: italic;
  color: var(--color-accent-dark);
  flex-shrink: 0;
  position: relative;
  padding-bottom: 4px;
}
.post-body :global(.h2-num::after) {
  content: '';
  display: block;
  width: 100%;
  height: 2px;
  background: var(--color-accent-dark);
  position: absolute;
  bottom: 0;
  left: 0;
  border-radius: 1px;
}
.post-body :global(.h2-title) {
  display: block;
  flex: 1;
  min-width: 0;
}
.post-body :global(h3) {
  font-family: var(--font-display);
  font-size: clamp(1.05rem, 2vw, 1.22rem);
  font-weight: 600;
  font-style: normal;
  color: var(--color-ink);
  margin: 2.2rem 0 0.8rem;
  line-height: 1.3;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10px;
  max-width: 100%;
}
.post-body :global(.h3-num) {
  font-family: var(--font-body);
  font-size: 0.78rem;
  font-weight: 500;
  font-style: normal;
  color: var(--color-accent-dark);
  flex-shrink: 0;
  opacity: 0.85;
}
.post-body :global(.h3-title) {
  display: block;
  flex: 1;
  min-width: 0;
}
.post-body :global(ul),
.post-body :global(ol) {
  margin: 0 0 1.6rem;
  padding-left: 1.5rem;
}
.post-body :global(li) {
  font-size: 1.02rem;
  line-height: 1.8;
  color: var(--color-text);
  margin-bottom: 0.5rem;
}
.post-body :global(strong) { font-weight: 600; color: var(--color-ink); }
.post-body :global(em) { font-style: italic; }
.post-body :global(a) {
  color: var(--color-accent-dark);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 3px;
  transition: color var(--transition);
}
.post-body :global(a:hover) { color: var(--color-ink); }

/* Blockquote — editorial pull-quote style */
.post-body :global(blockquote) {
  margin: 2.4rem 0;
  padding: 28px 36px;
  border-left: 3px solid var(--color-accent-dark);
  background: var(--color-surface);
}
.post-body :global(blockquote p) {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.2rem !important;
  line-height: 1.65 !important;
  color: var(--color-heading) !important;
  margin: 0 !important;
}

/* Images inside body */
.post-body :global(img) {
  width: 100%;
  max-width: 100%;
  height: auto;
  display: block;
  margin: 2.8rem 0;
  border-radius: 2px;
}
.post-body :global(figure) { margin: 2.8rem 0; }
.post-body :global(figure img) { margin: 0; }
.post-body :global(figcaption) {
  font-size: 0.78rem;
  color: var(--color-text-faint);
  text-align: center;
  margin-top: 10px;
  font-style: italic;
}

/* Tables — mobile scroll wrapper added via JS */
:global(.table-scroll-wrap) {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  margin: 2rem 0;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
}
.post-body :global(table) {
  width: 100%;
  min-width: 480px;
  border-collapse: collapse;
  font-size: 0.9rem;
  margin: 0;
}
.post-body :global(th) {
  background: var(--color-surface);
  padding: 11px 16px;
  text-align: left;
  font-weight: 600;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  border-bottom: 2px solid var(--color-border);
}
.post-body :global(td) {
  padding: 11px 16px;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-text);
  line-height: 1.6;
}
.post-body :global(tr:last-child td) { border-bottom: none; }

/* ── Continue reading ── */
.inline-related {
  margin: 48px 0;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  padding: 28px 0;
}
.inline-related-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin: 0 0 16px;
}
.inline-related-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.inline-related-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 0;
  text-decoration: none;
  border-bottom: 1px solid var(--color-border);
  transition: opacity var(--transition);
}
.inline-related-list li:last-child .inline-related-link { border-bottom: none; }
.inline-related-link:hover { opacity: 0.72; }
.ilr-left { display: flex; flex-direction: column; gap: 4px; }
.ilr-cat {
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-faint);
}
.ilr-title {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--color-heading);
  line-height: 1.3;
}
.ilr-arrow {
  font-size: 1rem;
  color: var(--color-text-faint);
  flex-shrink: 0;
}

/* ── Author bio ── */
.author-bio {
  display: flex;
  gap: 20px;
  align-items: flex-start;
  padding: 32px 0;
  border-top: 1px solid var(--color-border);
  margin: 48px 0 24px;
}
.author-avatar-circle {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: var(--color-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.author-initials {
  font-size: 0.8rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.05em;
}
.author-name {
  font-weight: 600;
  font-size: 0.88rem;
  color: var(--color-heading);
  margin: 0 0 6px;
  letter-spacing: 0.01em;
}
.author-desc {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.7;
  margin: 0;
}
.author-bio-link {
  color: var(--color-accent-dark);
  text-decoration: none;
  font-weight: 500;
  white-space: nowrap;
}
.author-bio-link:hover { text-decoration: underline; }

/* Tags */
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
  padding-bottom: 8px;
}
.post-tag {
  padding: 5px 14px;
  background: transparent;
  border: 1px solid var(--color-border);
  font-size: 0.7rem;
  color: var(--color-text-muted);
  letter-spacing: 0.06em;
  border-radius: 100px;
  transition: border-color var(--transition), color var(--transition);
  text-decoration: none;
  cursor: pointer;
}
.post-tag:hover { border-color: var(--color-ink); color: var(--color-ink); }

/* ══════════════════════════════════════════
   SIDEBAR
══════════════════════════════════════════ */
.post-sidebar {
  position: sticky;
  top: calc(var(--header-height) + 32px);
  display: flex;
  flex-direction: column;
  gap: 36px;
}

/* ── TOC — Elementor widget, site palette ── */
.toc-widget {
  --toc-bg:          var(--color-surface);
  --toc-border:      var(--color-border);
  --toc-title-color: var(--color-ink);
  --toc-link-color:  var(--color-text-muted);
  --toc-link-active: var(--color-accent-dark);
  --toc-icon-color:  var(--color-text-muted);

  background: var(--toc-bg);
  border: 1px solid var(--toc-border);
  border-radius: 6px;
  font-family: var(--font-body);
}
.toc-widget__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  cursor: pointer;
  background: #DDD0BE;
  border-radius: 6px 6px 0 0;
  user-select: none;
}
.toc-widget__header-title {
  margin: 0;
  flex: 1;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  color: var(--toc-title-color);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.toc-widget__toggle-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  color: var(--toc-icon-color);
}
.toc-widget__toggle-button svg {
  width: 14px;
  height: 14px;
  fill: currentColor;
}
.toc-widget__toggle-button--collapse { display: flex; }
.toc-widget__toggle-button--expand   { display: none;  }
.toc-widget.is-collapsed .toc-widget__toggle-button--collapse { display: none;  }
.toc-widget.is-collapsed .toc-widget__toggle-button--expand   { display: flex;  }
.toc-widget__body {
  overflow-y: auto;
  max-height: min(2000px, calc(100vh - var(--header-height) - 180px));
  transition: max-height 0.3s ease;
  border-top: 1px solid var(--toc-border);
  scrollbar-width: thin;
  scrollbar-color: var(--color-border) transparent;
}
.toc-widget.is-collapsed .toc-widget__body {
  max-height: 0;
  overflow: hidden;
  border-top-color: transparent;
}
:global(.toc-widget__list) {
  list-style: none;
  counter-reset: toc-counter;
  margin: 0;
  padding: 20px 20px;
}
:global(.toc-widget__list-item) {
  counter-increment: toc-counter;
  margin-bottom: 16px;
}
:global(.toc-widget__list-item:last-child) { margin-bottom: 0; }
:global(.toc-widget__list-item-text-wrapper) {
  display: flex;
  align-items: baseline;
  gap: 10px;
}
:global(.toc-widget__list-item-text-wrapper::before) {
  content: counter(toc-counter) ".";
  flex: 0 0 auto;
  font-size: 15px;
  font-weight: 400;
  color: var(--color-ink);
  min-width: 20px;
}
/* :global() so JS-created anchor elements are reached by scoped CSS */
:global(.toc-widget__list-item-text) {
  position: relative;
  display: inline;
  flex: 1 1 auto;
  font-size: 15px;
  line-height: 1.55;
  color: var(--color-ink);
  text-decoration: none;
  transition: color 0.2s ease;
}
:global(.toc-widget__list-item-text:hover) {
  color: var(--color-accent-dark);
  text-decoration: underline;
  text-underline-offset: 3px;
}
:global(.toc-widget__list-item-text.is-active) {
  color: var(--color-accent-dark);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 3px;
}
@media (max-width: 480px) { .toc-widget { max-width: 100%; } }

/* Sidebar CTA */
.sidebar-cta {
  background: var(--color-surface);
  padding: 24px;
  border-top: 2px solid var(--color-accent-dark);
}
.sidebar-cta-label {
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-accent-dark);
  margin: 0 0 10px;
}
.sidebar-cta-text {
  font-size: 0.83rem;
  color: var(--color-text-muted);
  line-height: 1.7;
  margin: 0 0 18px;
}
.sidebar-cta-btn {
  width: 100%;
  justify-content: center;
  font-size: 0.65rem;
  min-height: 42px;
  padding: 10px 20px;
}

/* ══════════════════════════════════════════
   RELATED POSTS
══════════════════════════════════════════ */
.related-section {
  border-top: 1px solid var(--color-border);
  padding: 72px 0 96px;
  background: #fff;
}
.related-heading {
  font-family: var(--font-body);
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 40px;
  letter-spacing: -0.01em;
}
.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}

/* Related post card — matches screenshot style */
.rel-card {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  transition: opacity 0.2s;
}
.rel-card:hover { opacity: 0.88; }
.rel-card-img-wrap {
  aspect-ratio: 16 / 10;
  overflow: hidden;
  border-radius: 12px;
  background: var(--color-surface);
  margin-bottom: 14px;
}
.rel-card-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.rel-card:hover .rel-card-img-wrap img { transform: scale(1.04); }
.rel-card-body { display: flex; flex-direction: column; gap: 6px; }
.rel-card-date {
  font-size: 0.76rem;
  color: var(--color-text-faint);
}
.rel-card-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.35;
  margin: 0;
  font-family: var(--font-body);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.rel-card-desc {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ══════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════ */
@media (max-width: 960px) {
  .post-layout { grid-template-columns: 1fr; gap: 0; }
  .post-sidebar { position: static; flex-direction: row; flex-wrap: wrap; gap: 24px; margin-top: 48px; }
  .sidebar-toc { flex: 1; min-width: 240px; }
  .sidebar-cta { flex: 1; min-width: 240px; }
  .related-grid { grid-template-columns: repeat(2, 1fr); }
  .related-grid .rel-card:last-child { display: none; }
}
@media (max-width: 640px) {
  /* Hero */
  .post-hero-wrap { height: 42vh; min-height: 200px; }

  /* Header */
  .post-header { padding: 24px 16px 20px; }
  .post-header-inner { max-width: 100%; }
  .post-meta { gap: 12px; flex-wrap: wrap; font-size: 0.8rem; }
  .breadcrumb { display: none; }

  /* Article */
  .post-wrap { padding: 28px 16px 48px; }
  .post-body :global(p) { font-size: 1rem; line-height: 1.85; }
  .post-body :global(p:first-child) { font-size: 1.05rem; }
  .post-body :global(h2) { font-size: 1.25rem; margin: 2rem 0 0.75rem; gap: 8px; }
  .post-body :global(h3) { font-size: 1.05rem; margin: 1.6rem 0 0.6rem; gap: 8px; }
  .post-body :global(blockquote) { padding: 16px 18px; margin: 1.6rem 0; }
  .post-body :global(blockquote p) { font-size: 1.05rem !important; }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.2rem; }

  /* Sidebar — moves above article on mobile */
  .post-layout { display: flex; flex-direction: column; }
  .post-sidebar { order: -1; flex-direction: column; margin-top: 0; margin-bottom: 28px; gap: 0; }
  .post-main { order: 1; }
  .sidebar-toc { display: block; width: 100%; min-width: unset; }
  .sidebar-cta { display: none; }

  /* Related */
  .related-grid { grid-template-columns: 1fr; }
  .related-grid .rel-card:last-child { display: flex; }
  .inline-related-link { align-items: flex-start; }

  /* Author */
  .author-bio { gap: 14px; padding: 24px 0; }
}
</style>

<script>
// ── Reading progress bar ─────────────────────────────────
const progressBar = document.getElementById('read-progress');
if (progressBar) {
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
    progressBar.style.width = pct + '%';
    progressBar.setAttribute('aria-valuenow', String(Math.round(pct)));
  }, { passive: true });
}

// ── Table mobile scroll wrap ──────────────────────────────
document.querySelectorAll<HTMLTableElement>('.post-body table').forEach(table => {
  const parent = table.parentNode;
  if (!parent) return;
  const wrap = document.createElement('div');
  wrap.className = 'table-scroll-wrap';
  parent.insertBefore(wrap, table);
  wrap.appendChild(table);
});

// ── H2 + H3 number decoration (single pass) ──────────────
const H2_SKIP = new Set(['tl;dr', 'tl:dr', '—', '–']);
const allHeadings = document.querySelectorAll<HTMLHeadingElement>('.post-body h2, .post-body h3');
let h2Counter = 0;
let h3Counter = 0;
allHeadings.forEach((h) => {
  const fullText = (h.textContent ?? '').trim();
  if (h.tagName === 'H2') {
    if (H2_SKIP.has(fullText.toLowerCase())) return;
    const stripped = fullText.replace(/^\d+\.\s*/, '').trim();
    h2Counter++;
    h3Counter = 0;
    const numSpan = document.createElement('span');
    numSpan.className = 'h2-num';
    numSpan.textContent = String(h2Counter).padStart(2, '0') + '.';
    const titleSpan = document.createElement('span');
    titleSpan.className = 'h2-title';
    titleSpan.textContent = stripped;
    h.textContent = '';
    h.appendChild(numSpan);
    h.appendChild(titleSpan);
  } else {
    if (h2Counter === 0) h2Counter = 1;
    h3Counter++;
    const numSpan = document.createElement('span');
    numSpan.className = 'h3-num';
    numSpan.textContent = `${h2Counter}.${h3Counter}`;
    const titleSpan = document.createElement('span');
    titleSpan.className = 'h3-title';
    titleSpan.textContent = fullText;
    h.textContent = '';
    h.appendChild(numSpan);
    h.appendChild(titleSpan);
  }
});

// ── TOC build + scroll spy ────────────────────────────────
const headings   = document.querySelectorAll<HTMLHeadingElement>('.post-body h2');
const tocList    = document.getElementById('sidebar-toc-list');
const sidebarToc = document.getElementById('sidebar-toc');

// Skip decorative headings that aren't real sections
const SKIP_TERMS = ['tl;dr', 'tl:dr', '—', '–'];

const tocHeadings = Array.from(headings).filter(h => {
  const t = (h.textContent ?? '').replace(/^\d+\.\s*/, '').trim().toLowerCase();
  return !SKIP_TERMS.includes(t);
});

if (tocHeadings.length < 2) {
  sidebarToc?.remove();
} else {
  // Build list items — Elementor widget structure
  tocHeadings.forEach((h, i) => {
    if (!h.id) h.id = `section-${i}`;

    const li      = document.createElement('li');
    li.className  = 'toc-widget__list-item';

    const wrapper = document.createElement('div');
    wrapper.className = 'toc-widget__list-item-text-wrapper';

    const a       = document.createElement('a');
    a.className   = 'toc-widget__list-item-text';
    a.href        = `#${h.id}`;
    a.textContent = (h.textContent ?? '').replace(/^\d+\.\s*/, '').trim();

    wrapper.appendChild(a);
    li.appendChild(wrapper);
    tocList?.appendChild(li);
  });

  const links = Array.from(tocList?.querySelectorAll<HTMLAnchorElement>('.toc-widget__list-item-text') ?? []);
  const tocBody = document.getElementById('toc-body');
  let prevActiveIndex = -1;

  function scrollTocToActive(index: number) {
    if (!tocBody || index < 0) return;
    const item = links[index]?.closest('li') as HTMLElement | null;
    if (!item) return;
    const itemTop    = item.offsetTop;
    const itemBottom = itemTop + item.offsetHeight;
    const scrollTop  = tocBody.scrollTop;
    const height     = tocBody.clientHeight;
    if (itemTop < scrollTop + 16) {
      tocBody.scrollTop = itemTop - 16;
    } else if (itemBottom > scrollTop + height - 16) {
      tocBody.scrollTop = itemBottom - height + 16;
    }
  }

  // Scroll spy — mirrors Elementor's elementor-item-active logic
  function setActive() {
    let activeIndex = -1;
    for (let i = 0; i < tocHeadings.length; i++) {
      const rect = tocHeadings[i].getBoundingClientRect();
      if (rect.top <= window.innerHeight * 0.35) activeIndex = i;
    }
    links.forEach((l, i) => {
      if (i === activeIndex) l.classList.add('is-active');
      else l.classList.remove('is-active');
    });
    if (activeIndex !== prevActiveIndex) {
      prevActiveIndex = activeIndex;
      scrollTocToActive(activeIndex);
    }
  }

  setActive();
  let rafId: number;
  window.addEventListener('scroll', () => {
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(setActive);
  }, { passive: true });

  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => { if (entry.isIntersecting) setActive(); });
  }, { rootMargin: '-10% 0px -55% 0px' });
  tocHeadings.forEach(h => observer.observe(h));

  // Start collapsed on mobile — user can expand by tapping header
  if (window.innerWidth <= 640) {
    sidebarToc?.classList.add('is-collapsed');
  }

  // Collapse toggle — toggles is-collapsed on the root .toc-widget element
  const tocHeader = document.getElementById('toc-header');
  tocHeader?.addEventListener('click', () => {
    sidebarToc?.classList.toggle('is-collapsed');
  });
}
</script>
